{
    "name": "axelraboit/aurora-client",
    "description": "Aurora-based client application — à-la-carte modules over VCS (no Packagist).",
    "type": "project",
    "license": "proprietary",
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require": {
        "php": ">=8.4",
        "symfony/runtime": "7.4.*",
        "axelraboit/aurora": "dev-split/core",
        "axelraboit/aurora-tools": "dev-master"
    },
    "require-dev": {
        "doctrine/doctrine-fixtures-bundle": "^4.3.1",
        "phpunit/phpunit": "^13.1.7",
        "symfony/browser-kit": "7.4.*",
        "symfony/css-selector": "7.4.*",
        "symfony/maker-bundle": "^1.67",
        "symfony/web-profiler-bundle": "7.4.*"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "repositories": [
        { "type": "vcs", "url": "git@github.com:AxelRaboit/aurora-core.git" },
        { "type": "vcs", "url": "git@github.com:AxelRaboit/aurora-tools.git" },
        { "type": "vcs", "url": "git@github.com:AxelRaboit/aurora-crm.git" },
        { "type": "vcs", "url": "git@github.com:AxelRaboit/aurora-billing.git" },
        { "type": "vcs", "url": "git@github.com:AxelRaboit/aurora-editorial.git" },
        { "type": "vcs", "url": "git@github.com:AxelRaboit/aurora-photo.git" },
        { "type": "vcs", "url": "git@github.com:AxelRaboit/aurora-project.git" },
        { "type": "vcs", "url": "git@github.com:AxelRaboit/aurora-hr.git" },
        { "type": "vcs", "url": "git@github.com:AxelRaboit/aurora-notes.git" },
        { "type": "vcs", "url": "git@github.com:AxelRaboit/aurora-personal-finance.git" },
        { "type": "vcs", "url": "git@github.com:AxelRaboit/aurora-planning.git" },
        { "type": "vcs", "url": "git@github.com:AxelRaboit/aurora-assistant.git" },
        { "type": "vcs", "url": "git@github.com:AxelRaboit/aurora-commerce.git" }
    ],
    "config": {
        "allow-plugins": {
            "php-http/discovery": true,
            "symfony/flex": true,
            "symfony/runtime": true
        }
    },
    "extra": {
        "symfony": {
            "require": "7.4.*"
        }
    }
}
