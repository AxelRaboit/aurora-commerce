{% extends 'Frontend/themes/default/auth/layout.html.twig' %}

{% block title %}{{ 'personal_finance.wallets.invitations.page_title'|trans }} - {{ parent() }}{% endblock %}

{% block frontend_body %}
<div class="max-w-md mx-auto px-4 sm:px-6 py-12">
    <div class="bg-surface border border-line rounded-lg p-6 sm:p-8 shadow-sm">

        {% if status == 'invalid' %}
            <h1 class="text-xl font-semibold text-primary mb-2">
                {{ 'personal_finance.wallets.invitations.invalid_title'|trans }}
            </h1>
            <p class="text-sm text-muted">
                {{ 'personal_finance.wallets.errors.invitation_token_invalid'|trans }}
            </p>

        {% elseif status == 'accepted' %}
            <h1 class="text-xl font-semibold text-primary mb-2">
                {{ 'personal_finance.wallets.invitations.already_accepted_title'|trans }}
            </h1>
            <p class="text-sm text-muted mb-6">
                {{ 'personal_finance.wallets.invitations.already_accepted_body'|trans({'{walletName}': invitation.wallet.name}) }}
            </p>
            <a href="{{ path('backend_personal_finance_wallets') }}" class="inline-flex items-center justify-center px-4 py-2 rounded-md bg-accent-600 text-white text-sm font-medium hover:bg-accent-500 transition">
                {{ 'personal_finance.wallets.invitations.go_to_wallets'|trans }}
            </a>

        {% elseif status == 'declined' %}
            <h1 class="text-xl font-semibold text-primary mb-2">
                {{ 'personal_finance.wallets.invitations.already_declined_title'|trans }}
            </h1>
            <p class="text-sm text-muted">
                {{ 'personal_finance.wallets.invitations.already_declined_body'|trans }}
            </p>

        {% elseif status == 'expired' %}
            <h1 class="text-xl font-semibold text-primary mb-2">
                {{ 'personal_finance.wallets.invitations.expired_title'|trans }}
            </h1>
            <p class="text-sm text-muted">
                {{ 'personal_finance.wallets.invitations.expired_body'|trans }}
            </p>

        {% else %}
            <h1 class="text-xl font-semibold text-primary mb-2">
                {{ 'personal_finance.wallets.invitations.pending_title'|trans }}
            </h1>
            <p class="text-sm text-muted mb-6">
                {{ 'personal_finance.wallets.invitations.pending_body'|trans({
                    '{inviterName}': invitation.invitedBy.name,
                    '{walletName}': invitation.wallet.name,
                    '{role}': ('personal_finance.wallets.roles.' ~ invitation.role.value)|trans,
                }) }}
            </p>

            <div class="flex flex-col sm:flex-row gap-3 mt-6">
                <form method="POST" action="{{ path('personal_finance_wallet_invitation_accept', {token: invitation.token}) }}" class="flex-1">
                    <button type="submit" class="w-full inline-flex items-center justify-center px-4 py-2 rounded-md bg-accent-600 text-white text-sm font-medium hover:bg-accent-500 transition">
                        {{ 'personal_finance.wallets.invitations.accept_action'|trans }}
                    </button>
                </form>
                <form method="POST" action="{{ path('personal_finance_wallet_invitation_decline', {token: invitation.token}) }}" class="flex-1">
                    <button type="submit" class="w-full inline-flex items-center justify-center px-4 py-2 rounded-md bg-surface-2 text-primary text-sm font-medium hover:bg-surface-3 transition border border-line">
                        {{ 'personal_finance.wallets.invitations.decline_action'|trans }}
                    </button>
                </form>
            </div>
        {% endif %}

    </div>
</div>
{% endblock %}
