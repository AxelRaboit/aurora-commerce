{% extends '@Core/backend/layout.html.twig' %}

{% block title %}{{ 'backend.nav.personal_finance_goals'|trans }} - {{ parent() }}{% endblock %}

{% block page_header_slot %}
    {{ include('@Shared/components/page_header.html.twig', {
        crumbs: [
            {label: 'backend.nav.sections.personal_finance'|trans},
            {label: 'backend.nav.personal_finance_goals'|trans},
        ],
    }) }}
{% endblock %}

{% block body %}
<div {{ vue_component('personalfinance/backend/goal/PersonalFinanceGoalsApp', {
    goals: goals,
    wallets: wallets,
    categoriesByWallet: categoriesByWallet,
    trackingModes: trackingModes,
    createPath: createPath,
    updatePath: updatePath,
    deletePath: deletePath,
    depositPath: depositPath,
}) }} class="flex-1 min-w-0"></div>
{% endblock %}
