{% extends '@Shared/email/layout/base.html.twig' %}

{% block title %}{{ 'ecommerce.mail.admin_new.subject'|trans }}{% endblock %}

{% block content %}
<h1>{{ 'ecommerce.mail.admin_new.heading'|trans }}</h1>
<p>{{ 'ecommerce.mail.admin_new.intro'|trans({'{number}': order.number}) }}</p>

<table class="panel" role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%">
    <tr>
        <td class="panel-content">
            <p style="margin:0 0 6px;"><strong>{{ 'ecommerce.mail.common.customer'|trans }} :</strong> {{ order.name }} &lt;{{ order.email }}&gt;</p>
            <p style="margin:0 0 6px;"><strong>{{ 'ecommerce.mail.common.total'|trans }} :</strong> {{ (order.totalCents / 100)|number_format(2, ',', ' ') }} {{ currency.symbol }}</p>
            <p style="margin:0;"><strong>{{ 'ecommerce.mail.common.items'|trans }} :</strong> {{ order.lines|length }}</p>
        </td>
    </tr>
</table>

{{ include('@Shared/email/partials/action_button.html.twig', {
    url: adminUrl,
    label: 'ecommerce.mail.admin_new.cta'|trans,
}) }}
{% endblock %}
