{% extends '@Core/backend/layout.html.twig' %}

{% block title %}{{ document.title }} - {{ 'backend.nav.documents'|trans }} - {{ parent() }}{% endblock %}

{% block page_header_slot %}
    {{ include('@Shared/components/page_header.html.twig', {
        crumbs: [
            {label: 'backend.nav.sections.ged'|trans},
            {label: 'backend.nav.documents'|trans, href: path('backend_ged_documents')},
            {label: document.title},
        ],
    }) }}
{% endblock %}

{% block body %}
<div {{ vue_component('ged/backend/documents/DocumentShowApp', {
    document: document,
    backPath: backPath,
    updatePath: updatePath,
    deletePath: deletePath,
    listPath: listPath,
}) }} class="flex-1 min-w-0"></div>
{% endblock %}
