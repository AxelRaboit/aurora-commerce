{% extends '@Shared/email/layout/base.html.twig' %}

{% block content %}
<h1>{{ ('crm.mail.deal.heading_' ~ newStage.value)|trans }}</h1>
<p>{{ ('crm.mail.deal.intro_' ~ newStage.value)|trans({'{name}': deal.name}) }}</p>

<table class="panel" role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%">
    <tr>
        <td class="panel-content">
            <p style="margin:0 0 6px;"><strong>{{ 'crm.mail.deal.name'|trans }} :</strong> {{ deal.name }}</p>
            {% if deal.value %}<p style="margin:0 0 6px;"><strong>{{ 'crm.mail.deal.value'|trans }} :</strong> {{ deal.value|number_format(2, ',', ' ') }} €</p>{% endif %}
            {% if deal.contact %}<p style="margin:0 0 6px;"><strong>{{ 'crm.mail.deal.contact'|trans }} :</strong> {{ deal.contact.fullName }}</p>{% endif %}
            {% if deal.company %}<p style="margin:0;"><strong>{{ 'crm.mail.deal.company'|trans }} :</strong> {{ deal.company.name }}</p>{% endif %}
        </td>
    </tr>
</table>
{% endblock %}
