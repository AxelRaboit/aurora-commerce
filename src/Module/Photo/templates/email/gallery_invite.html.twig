{% extends '@Shared/email/layout/base.html.twig' %}

{% block title %}{{ gallery.title }} — Vos photos sont prêtes{% endblock %}

{% block content %}
<h1>{{ gallery.title }}</h1>

<p>Bonjour {{ invite.name }},</p>

<p>
    Vos photos sont prêtes. Cliquez sur le bouton ci-dessous pour accéder à votre galerie privée.
    Ce lien vous est personnel — pas besoin de mot de passe.
</p>

{{ include('@Shared/email/partials/action_button.html.twig', {
    url: magicUrl,
    label: 'Accéder à ma galerie',
}) }}

<p style="color: #888; font-size: 12px; margin-top: 32px;">
    Si le bouton ne fonctionne pas, copiez ce lien dans votre navigateur :<br>
    <a href="{{ magicUrl }}">{{ magicUrl }}</a>
</p>

<p style="color: #888; font-size: 12px;">
    — {{ siteName }}
</p>
{% endblock %}
