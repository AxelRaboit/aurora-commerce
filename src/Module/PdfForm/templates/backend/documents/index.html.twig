{% extends '@Core/backend/layout.html.twig' %}

{% block title %}{{ 'backend.nav.pdfform_documents'|trans }} - {{ parent() }}{% endblock %}

{% block page_header_slot %}
    {{ include('@Shared/components/page_header.html.twig', {
        crumbs: [
            {label: 'backend.nav.sections.pdfform'|trans},
            {label: 'backend.nav.pdfform_documents'|trans},
        ],
    }) }}
{% endblock %}

{% block body %}
<div {{ vue_component('pdfform/backend/documents/PdfDocumentsApp', {
    documents: documents,
    templates: templates,
    search: search,
    generatePath: generatePath,
    deletePath: deletePath,
    listPath: listPath,
    templateListPath: templateListPath,
}) }} class="flex-1 min-w-0"></div>
{% endblock %}
