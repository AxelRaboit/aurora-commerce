{% set workflowTitle = workflow.template.title|default('?') %}
{% set workflowVersion = workflow.template.version|default('?') %}
{% set stepTitle = step.stepTemplate.title|default('?') %}
<!DOCTYPE html>
<html lang="{{ app.request.locale|default('fr') }}">
<head>
    <meta charset="UTF-8">
    <title>{{ 'welding.email.step_awaiting_validation.title'|trans({'reference': workflow.reference}) }}</title>
</head>
<body style="font-family: -apple-system, BlinkMacSystemFont, sans-serif; color: #1a1a1a; background: #f5f5f5; margin: 0; padding: 24px;">
    <table style="max-width: 560px; margin: 0 auto; background: #fff; border-radius: 8px; padding: 32px; border: 1px solid #e5e5e5;">
        <tr>
            <td>
                <h1 style="font-size: 18px; margin: 0 0 16px; color: #1a1a1a;">
                    {{ 'welding.email.step_awaiting_validation.title'|trans({'reference': workflow.reference}) }}
                </h1>

                <p style="font-size: 14px; line-height: 1.5;">
                    {{ 'welding.email.step_awaiting_validation.intro'|trans({'title': workflowTitle, 'version': workflowVersion})|raw }}
                </p>

                <table style="width: 100%; border-collapse: collapse; margin: 16px 0; font-size: 14px;">
                    <tr>
                        <td style="padding: 8px; background: #f5f5f5; width: 40%;">{{ 'welding.email.step_awaiting_validation.label_reference'|trans }}</td>
                        <td style="padding: 8px; font-family: monospace;">{{ workflow.reference }}</td>
                    </tr>
                    <tr>
                        <td style="padding: 8px; background: #f5f5f5;">{{ 'welding.email.step_awaiting_validation.label_step'|trans }}</td>
                        <td style="padding: 8px;">#{{ step.position + 1 }} — {{ stepTitle }}</td>
                    </tr>
                    {% if step.stepTemplate.validatorRole %}
                        <tr>
                            <td style="padding: 8px; background: #f5f5f5;">{{ 'welding.email.step_awaiting_validation.label_expected_role'|trans }}</td>
                            <td style="padding: 8px;">{{ ('welding.validator_role_' ~ step.stepTemplate.validatorRole.value)|trans }}</td>
                        </tr>
                    {% endif %}
                    {% if step.completedBy %}
                        <tr>
                            <td style="padding: 8px; background: #f5f5f5;">{{ 'welding.email.step_awaiting_validation.label_submitted_by'|trans }}</td>
                            <td style="padding: 8px;">{{ step.completedBy.name|default(step.completedBy.email|default('?')) }}</td>
                        </tr>
                    {% endif %}
                    {% if step.completedAt %}
                        <tr>
                            <td style="padding: 8px; background: #f5f5f5;">{{ 'welding.email.step_awaiting_validation.label_submitted_at'|trans }}</td>
                            <td style="padding: 8px;">{{ step.completedAt|date('d/m/Y H:i') }}</td>
                        </tr>
                    {% endif %}
                </table>

                {% if runnerUrl %}
                    <p style="margin: 24px 0; text-align: center;">
                        <a href="{{ runnerUrl }}" style="display: inline-block; background: #2563eb; color: #fff; padding: 10px 24px; border-radius: 6px; text-decoration: none; font-weight: 500; font-size: 14px;">
                            {{ 'welding.email.step_awaiting_validation.cta_open'|trans }}
                        </a>
                    </p>
                {% endif %}

                <p style="font-size: 12px; color: #6b7280; margin-top: 32px;">
                    {{ 'welding.email.step_awaiting_validation.footer'|trans({'siteName': siteName}) }}
                </p>
            </td>
        </tr>
    </table>
</body>
</html>
