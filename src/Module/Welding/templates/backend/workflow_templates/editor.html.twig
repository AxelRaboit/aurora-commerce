{% extends '@Core/backend/layout.html.twig' %}

{% block title %}{{ workflowTemplate.title }} - {{ 'backend.nav.welding_workflow_templates'|trans }} - {{ parent() }}{% endblock %}

{% block page_header_slot %}
    {{ include('@Shared/components/page_header.html.twig', {
        crumbs: [
            {label: 'backend.nav.sections.welding'|trans},
            {label: 'backend.nav.welding_workflow_templates'|trans, href: path('backend_welding_workflow_templates')},
            {label: workflowTemplate.title},
        ],
    }) }}
{% endblock %}

{% block body %}
<div {{ vue_component('welding/backend/workflow_templates/WeldingWorkflowTemplateEditorApp', {
    workflowTemplate: workflowTemplate,
    steps: steps,
}) }} class="flex-1 min-w-0"></div>
{% endblock %}
