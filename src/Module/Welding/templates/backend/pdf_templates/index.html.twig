    deletePath: deletePath,
    detectFieldsPath: detectFieldsPath,
    updateFieldPath: updateFieldPath,
    listPath: listPath,
    mediaPickerPath: mediaPickerPath,
}) }} class="flex-1 min-w-0"></div>
