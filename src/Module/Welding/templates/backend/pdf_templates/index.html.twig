{% extends '@Core/backend/layout.html.twig' %}

{% block title %}{{ 'backend.nav.welding_pdf_templates'|trans }} - {{ parent() }}{% endblock %}

{% block page_header_slot %}
    {{ include('@Shared/components/page_header.html.twig', {
        crumbs: [
            {label: 'backend.nav.sections.welding'|trans},
            {label: 'backend.nav.welding_pdf_templates'|trans},
        ],
    }) }}
{% endblock %}

{% block body %}
<div {{ vue_component('welding/backend/pdf_templates/WeldingPdfTemplatesApp', {
