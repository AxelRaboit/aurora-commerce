{% extends 'Frontend/themes/default/layout.html.twig' %}

{% block frontend_header %}
<header class="border-b" style="background-color: var(--th-header-bg, var(--th-surface)); border-color: var(--th-header-border, var(--color-border));">
    <div class="w-full px-4 sm:px-6 lg:px-8 py-4 flex items-center">
        <a href="{{ path('frontend_root') }}" class="flex items-center gap-2 text-lg" style="color: var(--th-header-text, var(--th-primary));">
            {% if siteFaviconUrl %}
                <img src="{{ siteFaviconUrl }}" alt="" class="h-8 w-8 object-cover rounded-xl shrink-0">
            {% endif %}
            <span>{{ context.siteName }}</span>
        </a>
    </div>
</header>
{% endblock %}

{% block frontend_footer %}{% endblock %}
