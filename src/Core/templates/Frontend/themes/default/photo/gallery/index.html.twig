{% extends 'Frontend/themes/default/photo/gallery/layout.html.twig' %}

{% block body %}
<div {{ vue_component('photo/frontend/GalleryViewApp', {
    gallery: {
        id: gallery.id,
        slug: gallery.slug,
        title: gallery.title,
        description: gallery.description,
        allowOriginals: gallery.allowOriginals,
        allowZipDownload: gallery.allowZipDownload,
        picksRequireIdentity: gallery.picksRequireIdentity,
        maxPicks: gallery.maxPicks,
        allowVisitorComments: gallery.allowVisitorComments,
        finalized: gallery.finalized,
        finalizedByName: gallery.finalizedByName,
    },
    items: items,
    visitorPicks: visitorPicks,
    favoriteCount: favoriteCount,
    visitorIdentity: visitorIdentity,
    finalizedByVisitor: finalizedByVisitor,
    readOnly: readOnly|default(false),
    sharePath: sharePath|default(null),
    pickPath: pickPath,
    commentPath: commentPath,
    finalizePath: finalizePath,
    downloadItemPath: downloadItemPath,
    downloadZipPath: downloadZipPath,
}) }}></div>
{% endblock %}
