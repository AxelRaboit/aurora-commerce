{% set _variant = variant|default('info') %}
{% set _strip = strip|default(false) %}

{% set _variants = {
    info: {strip: 'bg-sky-500/15 border-sky-500/40 text-sky-300', card: 'border-sky-300 bg-sky-50 text-sky-800 dark:border-sky-700 dark:bg-sky-950/40 dark:text-sky-300', defaultIcon: 'info'},
    success: {strip: 'bg-emerald-500/15 border-emerald-500/40 text-emerald-300', card: 'border-emerald-300 bg-emerald-50 text-emerald-800 dark:border-emerald-700 dark:bg-emerald-950/40 dark:text-emerald-300', defaultIcon: 'check-circle'},
    warning: {strip: 'bg-amber-500/15 border-amber-500/40 text-amber-300', card: 'border-amber-300 bg-amber-50 text-amber-800 dark:border-amber-700 dark:bg-amber-950/40 dark:text-amber-300', defaultIcon: 'alert-triangle'},
    danger: {strip: 'bg-rose-500/15 border-rose-500/40 text-rose-300', card: 'border-rose-300 bg-rose-50 text-rose-800 dark:border-rose-700 dark:bg-rose-950/40 dark:text-rose-300', defaultIcon: 'alert-circle'},
    trash: {strip: 'bg-rose-500/15 border-rose-500/40 text-rose-300', card: 'border-rose-300 bg-rose-50 text-rose-800 dark:border-rose-700 dark:bg-rose-950/40 dark:text-rose-300', defaultIcon: 'trash-2'},
} %}

{% set _config = _variants[_variant] ?? _variants.info %}
{% set _iconName = icon ?? _config.defaultIcon %}

<div class="{% if _strip %}px-4 py-2 flex items-center justify-center gap-3 text-xs border-b {{ _config.strip }}{% else %}flex items-start gap-3 rounded-lg border px-4 py-3 text-sm {{ _config.card }}{% endif %}">
    {% if _iconName %}
        {{ include('@Shared/components/icon.html.twig', {name: _iconName, class: _strip ? 'w-4 h-4 shrink-0' : 'w-4 h-4 shrink-0 mt-0.5', size: 16}) }}
    {% endif %}
    {% if _strip %}
        <span>{% block content %}{{ content|default('') }}{% endblock %}</span>
    {% else %}
        <div class="flex-1 min-w-0">{{ block('content') }}</div>
    {% endif %}
    {% block actions %}{% endblock %}
</div>
