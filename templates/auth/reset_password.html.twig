{% extends 'base_guest.html.twig' %}

{% block title %}{{ 'auth.reset_password.title'|trans }} — Velox{% endblock %}

{% block content %}
    <p class="mb-4 text-sm text-secondary">{{ 'auth.reset_password.instructions'|trans }}</p>

    <form method="POST" action="{{ path('app_reset_password', {selector: selector, token: token}) }}" class="space-y-4">
        <div>
            <label for="password" class="block text-sm font-medium text-secondary mb-1 uppercase">{{ 'auth.register.password'|trans }}</label>
            <div class="relative">
                <input type="password" id="password" name="password"
                       placeholder="••••••••"
                       class="w-full px-3 py-2 pr-10 border {% if errors.password is defined %}border-red-500{% else %}border-line{% endif %} rounded-md bg-surface-2 text-primary placeholder:text-muted focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition"
                       autocomplete="new-password" required autofocus>
                <button type="button" tabindex="-1"
                        class="absolute inset-y-0 right-0 flex items-center pr-3 text-muted hover:text-primary transition-colors"
                        onclick="var i=this.previousElementSibling;i.type=i.type==='password'?'text':'password'">
                    {{ include('components/icon.html.twig', {name: 'eye', class: 'w-4 h-4', size: 16}) }}
                </button>
            </div>
            {% if errors.password is defined %}
                <p class="mt-1 text-xs text-red-500">{{ errors.password }}</p>
            {% endif %}
        </div>

        <div>
            <label for="password_confirmation" class="block text-sm font-medium text-secondary mb-1 uppercase">{{ 'auth.register.password_confirm'|trans }}</label>
            <div class="relative">
                <input type="password" id="password_confirmation" name="password_confirmation"
                       placeholder="••••••••"
                       class="w-full px-3 py-2 pr-10 border {% if errors.password_confirmation is defined %}border-red-500{% else %}border-line{% endif %} rounded-md bg-surface-2 text-primary placeholder:text-muted focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition"
                       autocomplete="new-password" required>
                <button type="button" tabindex="-1"
                        class="absolute inset-y-0 right-0 flex items-center pr-3 text-muted hover:text-primary transition-colors"
                        onclick="var i=this.previousElementSibling;i.type=i.type==='password'?'text':'password'">
                    {{ include('components/icon.html.twig', {name: 'eye', class: 'w-4 h-4', size: 16}) }}
                </button>
            </div>
            {% if errors.password_confirmation is defined %}
                <p class="mt-1 text-xs text-red-500">{{ errors.password_confirmation }}</p>
            {% endif %}
        </div>

        <div class="flex justify-end">
            <button type="submit"
                    class="inline-flex items-center justify-center gap-2 rounded text-white font-bold py-2.5 px-4 bg-indigo-600 hover:bg-indigo-700 transition focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
                {{ 'auth.reset_password.submit'|trans }}
            </button>
        </div>
    </form>
{% endblock %}
