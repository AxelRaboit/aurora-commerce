{% extends 'base_guest.html.twig' %}

{% block title %}{{ 'auth.access_request.title'|trans }} — Velox{% endblock %}

{% block content %}
    <h2 class="text-lg font-bold text-primary mb-2">{{ 'auth.access_request.title'|trans }}</h2>
    <p class="text-sm text-secondary mb-5">{{ 'auth.access_request.description'|trans }}</p>

    <form method="POST" action="{{ path('app_access_request') }}" class="flex flex-col gap-4">
        <div>
            <label for="name" class="block text-sm font-medium text-secondary mb-1 uppercase">{{ 'auth.access_request.name'|trans }}</label>
            <input type="text" id="name" name="name"
                   value="{{ values.name ?? '' }}"
                   placeholder="{{ 'auth.access_request.name_placeholder'|trans }}"
                   class="w-full px-3 py-2 border border-line rounded-md bg-surface-2 text-primary placeholder:text-muted focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition"
                   autocomplete="name" autofocus>
        </div>

        <div>
            <label for="email" class="block text-sm font-medium text-secondary mb-1 uppercase">{{ 'auth.access_request.email'|trans }}</label>
            <input type="email" id="email" name="email"
                   value="{{ values.email ?? '' }}"
                   placeholder="{{ 'auth.login.email_placeholder'|trans }}"
                   class="w-full px-3 py-2 border {{ errors.email is defined ? 'border-red-500' : 'border-line' }} rounded-md bg-surface-2 text-primary placeholder:text-muted focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition"
                   autocomplete="email" required>
            {% if errors.email is defined %}
                <p class="mt-1 text-xs text-red-500">{{ errors.email }}</p>
            {% endif %}
        </div>

        <div>
            <label for="message" class="block text-sm font-medium text-secondary mb-1 uppercase">{{ 'auth.access_request.message'|trans }}</label>
            <textarea id="message" name="message" rows="4"
                      placeholder="{{ 'auth.access_request.message_placeholder'|trans }}"
                      class="w-full px-3 py-2 border border-line rounded-md bg-surface-2 text-primary placeholder:text-muted focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition resize-none">{{ values.message ?? '' }}</textarea>
        </div>

        <button type="submit"
                class="inline-flex items-center justify-center gap-2 w-full rounded text-white font-bold py-2.5 px-4 bg-indigo-600 hover:bg-indigo-700 transition focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
            {{ 'auth.access_request.submit'|trans }}
        </button>
    </form>

    <div class="mt-6 flex items-center gap-4">
        <div class="flex-1 border-t border-line"></div>
        <span class="text-sm text-secondary">ou</span>
        <div class="flex-1 border-t border-line"></div>
    </div>

    <p class="mt-4 text-center text-sm text-secondary">
        {{ 'auth.access_request.already_account'|trans }}
        <a href="{{ path('admin_login') }}" class="text-primary underline">{{ 'auth.access_request.login_link'|trans }}</a>
    </p>
{% endblock %}
