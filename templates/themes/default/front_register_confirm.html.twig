{% extends 'themes/default/layout.html.twig' %}

{% block title %}{{ 'front.register.confirm_title'|trans }} — {{ context.siteName }}{% endblock %}

{% block body %}
    <div class="max-w-md mx-auto py-16 px-4 text-center">
        <div class="w-14 h-14 rounded-full bg-success-soft flex items-center justify-center mx-auto mb-6">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 text-success" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
        </div>
        <h1 class="text-2xl font-bold text-primary mb-3">{{ 'front.register.confirm_heading'|trans }}</h1>
        <p class="text-secondary text-sm leading-relaxed mb-8">{{ 'front.register.confirm_message'|trans }}</p>
        <a href="{{ path('front_login', {locale: locale}) }}" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg bg-accent hover:bg-accent-hover text-white text-sm font-bold transition-colors">
            {{ 'front.login.submit'|trans }}
        </a>

        {% if pendingEmail %}
            <div class="mt-8 pt-8 border-t border-line/40">
                {% if resent %}
                    <p class="text-sm text-success">{{ 'front.register.resent_success'|trans }}</p>
                {% else %}
                    <p class="text-sm text-secondary mb-3">{{ 'front.register.resend_hint'|trans }}</p>
                    <form method="POST" action="{{ path('front_resend_verification', {locale: locale}) }}">
                        <button type="submit" class="text-sm text-accent hover:underline font-medium">
                            {{ 'front.register.resend_link'|trans }}
                        </button>
                    </form>
                {% endif %}
            </div>
        {% endif %}
    </div>
{% endblock %}
