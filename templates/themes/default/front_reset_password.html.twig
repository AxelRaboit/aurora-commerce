{% extends 'themes/default/layout.html.twig' %}

{% block title %}{{ 'front.reset_password.title'|trans }} — {{ context.siteName }}{% endblock %}

{% block body %}
<div {{ vue_component('FrontResetPasswordApp', {
    submitPath: path('front_reset_password', {locale: locale, selector: selector, token: token}),
    forgotPath: path('front_forgot_password', {locale: locale}),
    invalid: invalid,
    initialErrors: errors,
}) }}></div>
{% endblock %}
