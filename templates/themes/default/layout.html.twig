<!DOCTYPE html>
<html lang="{{ locale }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}{{ context.siteName }}{% endblock %}</title>
    {% set pageDescription = pageDescription|default(context.siteDescription ?? '') %}
    {% set alternates = alternates|default([]) %}
    {% block meta %}
        <meta name="description" content="{{ pageDescription }}">
        <meta property="og:title" content="{{ block('title') }}">
        <meta property="og:description" content="{{ pageDescription }}">
        <meta property="og:type" content="website">
        <meta property="og:site_name" content="{{ context.siteName }}">
        <meta property="og:locale" content="{{ locale }}">
        {% for alt in alternates %}
            {% if alt.locale != locale %}
                <meta property="og:locale:alternate" content="{{ alt.locale }}">
            {% endif %}
        {% endfor %}
        {% for alt in alternates %}
            <link rel="alternate" hreflang="{{ alt.locale }}" href="{{ context.siteUrl }}{{ alt.url }}">
            {% if alt.locale == context.defaultLocale %}
                <link rel="alternate" hreflang="x-default" href="{{ context.siteUrl }}{{ alt.url }}">
            {% endif %}
        {% endfor %}
        {% block og_image %}{% endblock %}
        {% block canonical %}{% endblock %}
        {% block robots %}{% endblock %}
        {% block jsonld %}{% endblock %}
    {% endblock %}

    {# Reuse admin CSS for a base tailwind setup; keep front independent of admin assets otherwise. #}
    {% if siteFaviconUrl %}
        <link rel="icon" href="{{ siteFaviconUrl }}">
    {% else %}
        <link rel="icon" type="image/svg+xml" href="/favicon.svg">
    {% endif %}

    {{ vite_entry_link_tags('app') }}

    <link rel="alternate" type="application/rss+xml" title="{{ context.siteName }} - RSS" href="{{ path('front_rss', {locale: locale}) }}">
    {% set cssOverrides = themeContext.cssVariableOverrides() %}
    {% if cssOverrides %}
    <style>:root { {{ cssOverrides|raw }} }</style>
    {% endif %}
</head>
<body class="min-h-screen bg-bg text-primary flex flex-col">
    <header style="background-color: var(--th-header-bg, var(--th-surface)); border-color: var(--th-header-border, var(--color-border)); color: var(--th-header-text, var(--th-primary));" class="border-b">
        <div class="max-w-5xl mx-auto px-4 py-4 flex items-center gap-6 flex-wrap">
            <a href="{{ path('front_home', {locale: locale}) }}" class="flex items-center gap-2 text-lg font-bold" style="color: var(--th-header-text, var(--th-primary));">
                {% set themeLogoUrl = themeContext.headerLogoUrl() %}
                {% set themeText = themeContext.headerCustomText() %}
                {% if themeLogoUrl %}
                    <img src="{{ themeLogoUrl }}" alt="{{ context.siteName }}" class="h-8 w-auto object-contain">
                {% elseif themeText %}
                    {{ themeText }}
                {% elseif siteLogoUrl %}
                    <img src="{{ siteLogoUrl }}" alt="{{ context.siteName }}" class="h-8 w-auto object-contain">
                {% else %}
                    {{ context.siteName }}
                {% endif %}
            </a>
            {% if context.activeLocales|length > 1 %}
                {% set alternatesByLocale = {} %}
                {% for alt in alternates %}
                    {% set alternatesByLocale = alternatesByLocale|merge({(alt.locale): alt.url}) %}
                {% endfor %}
                <div class="ml-auto flex items-center gap-1 text-xs">
                    {% for loc in context.activeLocales %}
                        {% set href = alternatesByLocale[loc.code] ?? path('front_home', {locale: loc.code}) %}
                        <a href="{{ href }}"
                           hreflang="{{ loc.code }}"
                           class="px-2 py-1 rounded {{ locale == loc.code ? 'bg-indigo-600 text-white' : 'text-muted hover:text-primary' }}">
                            {{ loc.code|upper }}
                        </a>
                    {% endfor %}
                </div>
            {% endif %}
        </div>
    </header>

    <main class="flex-1 max-w-5xl w-full mx-auto px-4 py-8">
        {% block body %}{% endblock %}
    </main>

    <footer style="background-color: var(--th-footer-bg, var(--th-surface)); border-color: var(--th-footer-border, var(--color-border));" class="border-t mt-12">
        <div class="max-w-5xl mx-auto px-4 py-6 text-center text-xs" style="color: var(--th-footer-text, var(--th-muted));">
            {{ themeContext.footerText(context.siteName) }}
        </div>
    </footer>
</body>
</html>
