{% extends 'base_guest.html.twig' %}

{% block title %}{{ 'auth.access_request.title'|trans }} - {{ parent() }}{% endblock %}

{% block content %}
    <div {{ vue_component('AdminAccessRequestApp', {
        submitPath: path('admin_access_request'),
        loginPath: path('admin_login'),
        initialErrors: errors,
        values: {
            name: values.name ?? '',
            email: values.email ?? '',
            message: values.message ?? '',
        },
    }) }}></div>
{% endblock %}
