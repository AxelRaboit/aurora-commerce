{% extends 'admin/layout.html.twig' %}

{% block title %}{{ 'nav.tags'|trans }} - {{ parent() }}{% endblock %}

{% block page_header_slot %}
    {{ include('components/page_header.html.twig', {title: 'nav.tags'|trans}) }}
{% endblock %}

{% block body %}
<div id="app-tags"
     data-locale="{{ app.request.locale }}"
     data-tags="{{ tags|json_encode|e('html_attr') }}"
     data-search="{{ search }}"
     data-tags-path="{{ path('admin_tags') }}"
     data-create-path="{{ path('admin_tags_create') }}"
     data-edit-path="{{ path('admin_tags_edit', {id: '__id__'}) }}"
     data-delete-path="{{ path('admin_tags_delete', {id: '__id__'}) }}"
     class="flex-1">
</div>
{% endblock %}

{% block stylesheets %}{{ parent() }}{{ vite_entry_link_tags('admin/tags') }}{% endblock %}
{% block javascripts %}{{ parent() }}{{ vite_entry_script_tags('admin/tags') }}{% endblock %}
