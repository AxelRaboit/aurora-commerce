<!DOCTYPE html>
<html lang="{{ app.request.locale }}">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{% block title %}Velox{% endblock %}</title>
        <link rel="icon" type="image/svg+xml" href="/favicon.svg">
        <link rel="preconnect" href="https://fonts.bunny.net">
        <link rel="stylesheet" href="https://fonts.bunny.net/css?family=inter:400,500,600,700&display=swap">
        {{ include('shared/components/theme_script.html.twig', {colorScheme: true}) }}
        {{ vite_entry_link_tags('app') }}
        {{ vite_entry_link_tags('flash') }}
        {{ vite_entry_script_tags('app') }}
        {{ vite_entry_script_tags('flash') }}
        {{ vite_entry_script_tags('theme') }}
        {{ vite_entry_script_tags('guest') }}
        <script>window.__flash__ = {{ app.flashes|json_encode|raw }};</script>
    </head>
    <body class="transition-colors duration-200">

        <div id="guest-toggle"></div>

        {% set hero_content %}{% block hero %}{% endblock %}{% endset %}
        {% set form_content %}{% block content %}{% endblock %}{% endset %}

        {% if hero_content|trim %}
            <div class="flex min-h-screen items-center justify-center bg-bg px-4 py-12">
                <div class="w-full max-w-5xl grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">
                    <div>
                        {{ include('shared/components/app_logo.html.twig', {
                            gradientId: 'velox-logo-hero',
                            href: path('admin_login'),
                            linkClass: 'inline-flex items-center gap-3 mb-8',
                            withText: true,
                            appVersion: appVersion ?? null,
                        }) }}
                        {{ hero_content|raw }}
                    </div>
                    <div class="w-full bg-surface border border-line px-6 py-6 shadow-md rounded-xl">
                        {{ form_content|raw }}
                    </div>
                </div>
            </div>
        {% else %}
            <div class="flex min-h-screen flex-col items-center justify-center bg-bg px-4 py-12">
                {{ include('shared/components/app_logo.html.twig', {
                    gradientId: 'velox-logo-stack',
                    href: path('admin_login'),
                    linkClass: 'flex flex-col items-center gap-2 mb-6',
                    withText: true,
                    textClass: 'text-primary font-bold text-2xl',
                    versionClass: 'text-xs text-secondary',
                    textLayout: 'contents',
                    appVersion: appVersion ?? null,
                }) }}
                <div class="w-full bg-surface border border-line px-6 py-6 shadow-md rounded-xl sm:max-w-md">
                    {{ form_content|raw }}
                </div>
            </div>
        {% endif %}

    </body>
</html>
