{% extends 'admin/layout.html.twig' %}

{% block title %}{{ 'admin.nav.posts'|trans }} - {{ parent() }}{% endblock %}

{% block page_header_slot %}
    {{ include('shared/components/page_header.html.twig', {title: 'admin.nav.posts'|trans}) }}
{% endblock %}

{% block body %}
<div {{ vue_component('admin/PostsApp', {
    postsPath: path('admin_posts'),
    posts: posts,
    search: search,
    postTypes: postTypes,
    taxonomies: taxonomies,
    locales: locales,
    trashed: trashed,
    createPath: path('admin_posts_create'),
    showPath: path('admin_posts_show', {id: '__id__'}),
    editPath: path('admin_posts_edit', {id: '__id__'}),
    deletePath: path('admin_posts_delete', {id: '__id__'}),
    restorePath: path('admin_posts_restore', {id: '__id__'}),
    forceDeletePath: path('admin_posts_force_delete', {id: '__id__'}),
    emptyTrashPath: path('admin_posts_empty_trash'),
}) }} class="flex-1 min-w-0"></div>
{% endblock %}
