{% extends 'front/themes/default/layout.html.twig' %}

{% block title %}{{ 'front.register.title'|trans }} — {{ context.siteName }}{% endblock %}

{% block body %}
<div {{ vue_component('front/auth/RegisterApp', {
    registerPath: path('front_register', {locale: locale}),
    loginPath: path('front_login', {locale: locale}),
    registrationEnabled: registrationEnabled,
    initialErrors: errors,
    values: {name: values.name ?? '', email: values.email ?? ''},
}) }}></div>
{% endblock %}
