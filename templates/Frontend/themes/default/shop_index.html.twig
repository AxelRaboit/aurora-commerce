{% extends 'Frontend/themes/default/layout.html.twig' %}

{% block title %}{{ 'frontend.shop.title'|trans }} — {{ context.siteName }}{% endblock %}

{% block body %}
<div {{ vue_component('ecommerce/frontend/ShopIndexApp', {
    listings: listings,
    pagination: pagination,
    locale: locale,
    productPathBase: path('frontend_shop_product', {locale: locale, slug: 'SLUG'})|replace({'/SLUG': ''}),
    indexPath: path('frontend_shop_index', {locale: locale}),
}) }}></div>
{% endblock %}
