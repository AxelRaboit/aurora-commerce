{% extends 'Frontend/themes/default/layout.html.twig' %}

{% set pageTitle = translationData.metaTitle ?? translationData.title ?? context.siteName %}
{% set pageDescription = translationData.metaDescription ?? context.siteDescription ?? '' %}
{% set ogImageUrl = translationData.ogImage.publicUrl ?? featuredMediaData.publicUrl ?? null %}
{% set canonicalUrl = translationData.canonicalUrl ?: (translationData.slug ? (context.siteUrl ~ path('editorial_post', {locale: locale, postTypeSlug: postData.postType.slug, slug: translationData.slug})) : null) %}

{% block title %}{{ pageTitle }} — {{ context.siteName }}{% endblock %}

{% block og_image %}
    {% if ogImageUrl %}
        <meta property="og:image" content="{{ context.siteUrl }}{{ ogImageUrl }}">
    {% endif %}
    <meta property="og:type" content="article">
    {% if postData.publishedAt %}
        <meta property="article:published_time" content="{{ postData.publishedAt }}">
    {% endif %}
{% endblock %}

{% block canonical %}
    {% if canonicalUrl %}<link rel="canonical" href="{{ canonicalUrl }}">{% endif %}
{% endblock %}

{% block robots %}
    {% if translationData.noindex %}<meta name="robots" content="noindex, nofollow">{% endif %}
{% endblock %}

{% block jsonld %}
    {% if translationData.jsonLd %}
        <script type="application/ld+json">{{ translationData.jsonLd|json_encode|raw }}</script>
    {% endif %}
{% endblock %}

{% block body %}
<div {{ vue_component('editorial/frontend/PostApp', {
    post: postData,
    translation: translationData,
    featuredMedia: featuredMediaData,
    content: content,
    commentsEnabled: commentsEnabled,
    locale: locale,
    listPath: translationData.slug ? path('editorial_post_comments_list', {locale: locale, postTypeSlug: postData.postType.slug, slug: translationData.slug}) : null,
    submitPath: translationData.slug ? path('editorial_post_comment', {locale: locale, postTypeSlug: postData.postType.slug, slug: translationData.slug}) : null,
    reactPathTemplate: translationData.slug ? path('editorial_comment_react', {locale: locale, postTypeSlug: postData.postType.slug, slug: translationData.slug, commentId: '__commentId__'}) : null,
}) }}></div>
{% endblock %}
