{% extends 'Frontend/themes/default/layout.html.twig' %}

{% set pageTitle = translation.metaTitle ?? translation.title ?? context.siteName %}
{% set pageDescription = translation.metaDescription ?? context.siteDescription ?? '' %}
{% set featuredMedia = post.featuredMedia %}
{% set ogMedia = translation.ogImage ?? featuredMedia %}
{% set canonicalUrl = translation.canonicalUrl ?: (translation.slug ? (context.siteUrl ~ path('editorial_post', {locale: locale, postTypeSlug: post.postType.slug, slug: translation.slug})) : null) %}

{% block title %}{{ pageTitle }} — {{ context.siteName }}{% endblock %}

{% block og_image %}
    {% if ogMedia %}
        <meta property="og:image" content="{{ context.siteUrl }}{{ ogMedia.publicUrl }}">
    {% endif %}
    <meta property="og:type" content="article">
    {% if post.publishedAt %}
        <meta property="article:published_time" content="{{ post.publishedAt|date('c') }}">
    {% endif %}
{% endblock %}

{% block canonical %}
    {% if canonicalUrl %}<link rel="canonical" href="{{ canonicalUrl }}">{% endif %}
{% endblock %}

{% block robots %}
    {% if translation.noindex %}<meta name="robots" content="noindex, nofollow">{% endif %}
{% endblock %}

{% block jsonld %}
    {% if translation.jsonLd %}
        <script type="application/ld+json">{{ translation.jsonLd|json_encode|raw }}</script>
    {% endif %}
{% endblock %}

{% block body %}
    <article class="max-w-3xl mx-auto">
        <header class="mb-8">
            <h1 class="text-4xl font-bold text-primary mb-2">{{ translation.title }}</h1>
            {% if post.publishedAt %}
                <time datetime="{{ post.publishedAt|date('c') }}" class="text-sm text-muted">
                    {{ post.publishedAt|date('d/m/Y') }}
                </time>
            {% endif %}
            {% if featuredMedia %}
                <figure class="mt-6">
                    <img
                        src="{{ featuredMedia.variantUrl('large') ?? featuredMedia.publicUrl }}"
                        alt="{{ featuredMedia.alt ?? translation.title ?? '' }}"
                        class="w-full h-auto rounded-lg"
                        style="object-position: {{ featuredMedia.focalPositionCss }}"
                        loading="lazy"
                    >
                </figure>
            {% endif %}
        </header>

        <div class="prose prose-lg dark:prose-invert max-w-none prose-headings:text-primary prose-a:text-accent hover:prose-a:text-accent-hover prose-a:no-underline prose-code:text-primary prose-pre:bg-surface-2 prose-pre:border prose-pre:border-line prose-blockquote:border-accent prose-blockquote:bg-surface-2 prose-blockquote:not-italic prose-img:rounded-lg prose-hr:border-line">
            {{ content|raw }}
        </div>
    </article>

    {% if translation.slug %}
        <div {{ vue_component('editorial/frontend/PostCommentsApp', {
            listPath: path('editorial_post_comments_list', {locale: locale, postTypeSlug: post.postType.slug, slug: translation.slug}),
            submitPath: path('editorial_post_comment', {locale: locale, postTypeSlug: post.postType.slug, slug: translation.slug}),
            reactPathTemplate: path('editorial_comment_react', {locale: locale, postTypeSlug: post.postType.slug, slug: translation.slug, commentId: '__commentId__'}),
            commentsEnabled: commentsEnabled,
        }) }}></div>
    {% endif %}
{% endblock %}
