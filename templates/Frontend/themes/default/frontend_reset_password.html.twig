{% extends 'Frontend/themes/default/frontend_auth_layout.html.twig' %}

{% block title %}{{ 'frontend.reset_password.title'|trans }} — {{ context.siteName }}{% endblock %}

{% block body %}
<div {{ vue_component('core/frontend/auth/ResetPasswordApp', {
    submitPath: path('frontend_reset_password', {locale: locale, selector: selector, token: token}),
    forgotPath: path('frontend_forgot_password', {locale: locale}),
    invalid: invalid,
    initialErrors: errors,
}) }}></div>
{% endblock %}
