{% extends 'Frontend/themes/default/layout.html.twig' %}

{% block title %}{{ category.seoTitle ?? category.name }} — {{ context.siteName }}{% endblock %}
{% block pageDescription %}{{ category.seoDescription ?? '' }}{% endblock %}

{% block body %}
<section class="shop-category">
    <nav class="shop-category__breadcrumb" aria-label="breadcrumb">
        <a href="{{ path('frontend_shop_index', {locale: locale}) }}">{{ 'frontend.shop.title'|trans }}</a>
        {% for crumb in breadcrumb %}
            <span class="shop-category__breadcrumb-sep">/</span>
            <a href="{{ path('frontend_shop_category', {locale: locale, slug: crumb.slug}) }}">{{ crumb.name }}</a>
        {% endfor %}
        <span class="shop-category__breadcrumb-sep">/</span>
        <span aria-current="page">{{ category.name }}</span>
    </nav>

    <header class="shop-category__header">
        <h1>{{ category.name }}</h1>
        {% if category.description %}
            <div class="shop-category__description">{{ category.description|raw }}</div>
        {% endif %}
    </header>

    {% if listings is empty %}
        <p class="shop-category__empty">{{ 'frontend.shop.empty'|trans }}</p>
    {% else %}
        <ul class="shop-category__grid">
            {% for listing in listings %}
                <li class="shop-category__item">
                    <a href="{{ path('frontend_shop_product', {locale: locale, slug: listing.slug}) }}">
                        {% if listing.featuredImage is defined and listing.featuredImage %}
                            <img src="{{ listing.featuredImage.url ?? '' }}" alt="{{ listing.displayTitle ?? listing.marketingTitle ?? '' }}">
                        {% else %}
                            <span class="shop-category__no-image">{{ 'frontend.shop.no_image'|trans }}</span>
                        {% endif %}
                        <h2>{{ listing.displayTitle ?? listing.marketingTitle ?? listing.slug }}</h2>
                        {% if listing.marketingDescription %}
                            <p>{{ listing.marketingDescription }}</p>
                        {% endif %}
                    </a>
                </li>
            {% endfor %}
        </ul>

        {{ include('Frontend/themes/default/editorial/_pagination.html.twig', {
            page: page,
            totalPages: totalPages,
            route: 'frontend_shop_category',
            params: {locale: locale, slug: category.slug},
        }) }}
    {% endif %}
</section>
{% endblock %}
