{% extends 'Frontend/themes/default/layout.html.twig' %}

{% block title %}{{ 'frontend.shop.title'|trans }} — {{ context.siteName }}{% endblock %}

{% block body %}
<div {{ vue_component('ecommerce/frontend/ShopIndexApp', {
    listings: listings,
    initialPage: page,
    initialTotalPages: totalPages,
    initialTotal: total,
    locale: locale,
    rootCategories: rootCategories ?? [],
    availableTags: availableTags ?? [],
    productPathBase: path('frontend_shop_product', {locale: locale, slug: 'SLUG'})|replace({'/SLUG': ''}),
    categoryPathBase: path('frontend_shop_category', {locale: locale, slug: 'SLUG'})|replace({'/SLUG': ''}),
    tagPathBase: path('frontend_shop_tag', {locale: locale, slug: 'SLUG'})|replace({'/SLUG': ''}),
    indexPath: path('frontend_shop_index', {locale: locale}),
    searchPath: path('frontend_shop_search', {locale: locale}),
}) }}></div>
{% endblock %}
