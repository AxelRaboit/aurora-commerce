{% extends '@Shared/email/layout/base.html.twig' %}

{% block content %}
<h1>{{ 'shared.mail.access_request_admin.heading'|trans }}</h1>
<p>{{ 'shared.mail.access_request_admin.intro'|trans }}</p>

<table class="panel" role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%">
    <tr>
        <td class="panel-content">
            <p style="margin:0 0 6px;"><strong>{{ 'shared.mail.access_request_admin.label_name'|trans }} :</strong> {{ request.requesterName ?? '-' }}</p>
            <p style="margin:0;"><strong>{{ 'shared.mail.access_request_admin.label_email'|trans }} :</strong> {{ request.requesterEmail }}</p>
        </td>
    </tr>
</table>

{% if request.message %}
<p><strong>{{ 'shared.mail.access_request_admin.label_message'|trans }} :</strong></p>
<table class="panel" role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%">
    <tr>
        <td class="panel-content">{{ request.message }}</td>
    </tr>
</table>
{% endif %}

{% if adminUrl is defined %}
{{ include('@Shared/email/partials/action_button.html.twig', {
    url: adminUrl,
    label: 'shared.mail.access_request_admin.cta'|trans,
}) }}
{% endif %}

<p class="warning">{{ 'shared.mail.access_request_admin.footer_note'|trans }}</p>
{% endblock %}
