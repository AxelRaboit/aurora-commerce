{#
    Twig mirror of assets/shared/components/nav/AppPagination.vue.

    Renders a paginator that builds real links via Symfony's `path()` — meant for
    server-rendered listings (front theme, public archives). Vue-driven admin
    listings should keep using <AppPagination> with `@change`.

    Visual rules MUST stay in sync with AppPagination.vue:
      - shows "Page X of Y" indicator
      - shows numbered pages only when totalPages ≤ 10
      - prev / next labels collapse to chevrons on mobile

    Params:
      - page         current page (1-indexed)
      - totalPages   total number of pages
      - route        Symfony route name to link to
      - params       (optional) extra route params merged with `page`
#}
{% set _params = params|default({}) %}

{% if totalPages > 1 %}
    <div class="flex flex-col sm:flex-row items-center sm:justify-between gap-3 text-sm">
        <span class="text-secondary shrink-0 order-2 sm:order-1">
            {{ 'shared.common.pagination'|trans({'{page}': page, '{totalPages}': totalPages}) }}
        </span>

        <div class="flex items-center gap-1 order-1 sm:order-2">
            {% if page > 1 %}
                <a href="{{ path(route, _params|merge({page: page - 1})) }}"
                   class="inline-flex items-center justify-center gap-2 rounded-lg py-1.5 px-3 text-xs bg-transparent hover:bg-surface-2 text-secondary hover:text-primary transition duration-150 ease-in-out">
                    {{ include('@Shared/components/icon.html.twig', {name: 'chevron-left', class: 'w-4 h-4 sm:hidden'}) }}
                    <span class="hidden sm:inline">{{ 'shared.pagination.previous'|trans }}</span>
                </a>
            {% else %}
                <span class="inline-flex items-center justify-center gap-2 rounded-lg py-1.5 px-3 text-xs text-secondary opacity-50 cursor-not-allowed">
                    {{ include('@Shared/components/icon.html.twig', {name: 'chevron-left', class: 'w-4 h-4 sm:hidden'}) }}
                    <span class="hidden sm:inline">{{ 'shared.pagination.previous'|trans }}</span>
                </span>
            {% endif %}

            {% if totalPages <= 10 %}
                {% for pageNum in 1..totalPages %}
                    {% if pageNum == page %}
                        <span class="w-8 h-8 inline-flex items-center justify-center rounded-lg text-sm transition-colors bg-accent-600 text-white shadow-sm">{{ pageNum }}</span>
                    {% else %}
                        <a href="{{ path(route, _params|merge({page: pageNum})) }}" class="w-8 h-8 inline-flex items-center justify-center rounded-lg text-sm transition-colors bg-surface-2 text-secondary hover:bg-surface-3">{{ pageNum }}</a>
                    {% endif %}
                {% endfor %}
            {% endif %}

            {% if page < totalPages %}
                <a href="{{ path(route, _params|merge({page: page + 1})) }}"
                   class="inline-flex items-center justify-center gap-2 rounded-lg py-1.5 px-3 text-xs bg-transparent hover:bg-surface-2 text-secondary hover:text-primary transition duration-150 ease-in-out">
                    <span class="hidden sm:inline">{{ 'shared.pagination.next'|trans }}</span>
                    {{ include('@Shared/components/icon.html.twig', {name: 'chevron-right', class: 'w-4 h-4 sm:hidden'}) }}
                </a>
            {% else %}
                <span class="inline-flex items-center justify-center gap-2 rounded-lg py-1.5 px-3 text-xs text-secondary opacity-50 cursor-not-allowed">
                    <span class="hidden sm:inline">{{ 'shared.pagination.next'|trans }}</span>
                    {{ include('@Shared/components/icon.html.twig', {name: 'chevron-right', class: 'w-4 h-4 sm:hidden'}) }}
                </span>
            {% endif %}
        </div>
    </div>
{% endif %}
