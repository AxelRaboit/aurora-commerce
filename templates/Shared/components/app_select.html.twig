{#
    Twig mirror of assets/shared/components/AppSelect.vue.
    Use for native <select> elements in Twig-rendered pages (front theme, auth, checkout…).

    Params:
      name        — form field name (required)
      label       — visible label (optional, omit for inline use)
      options     — { value: 'displayed text', … } — typically CountryEnum::options(locale)
      selected    — currently-selected value
      placeholder — first <option value=""> label; omit to skip
      required    — boolean, default false
      error       — translation key or message for validation feedback
      class       — extra utility classes appended to the wrapper
#}
<div class="flex flex-col gap-1.5 {{ class|default('') }}">
    {% if label is defined and label %}
        <label class="block text-xs font-medium text-secondary">
            {{ label|trans }}{% if required ?? false %} <span class="text-rose-400">*</span>{% endif %}
        </label>
    {% endif %}
    <select
        name="{{ name }}"
        {% if required ?? false %}required{% endif %}
        class="block w-full rounded-md border border-line bg-surface px-3 py-2 text-sm text-primary focus:border-accent-500 focus:ring-1 focus:ring-accent-500 transition{% if error is defined and error %} border-rose-500 focus:border-rose-500 focus:ring-rose-500{% endif %}"
    >
        {% if placeholder is defined and placeholder %}
            <option value="">{{ placeholder|trans }}</option>
        {% endif %}
        {% for value, displayed in options %}
            <option value="{{ value }}" {% if selected is defined and selected == value %}selected{% endif %}>{{ displayed }}</option>
        {% endfor %}
    </select>
    {% if error is defined and error %}<p class="text-xs text-rose-400">{{ error|trans }}</p>{% endif %}
</div>
