{#
  SVG icon component.
  Usage: {{ include('components/icon.html.twig', { name: 'moon', class: 'w-5 h-5 text-muted' }) }}

  Parameters:
    name   (string) – icon name (see list below)
    class  (string) – CSS classes, default 'w-5 h-5'
    size   (int)    – HTML width/height attribute in px, default 20
    stroke (string) – stroke-width value, default '2'

  Available icons: moon, sun, user-check, file-text, sliders, image, zap, eye,
                   info, alert-triangle, alert-circle, check-circle, trash-2
#}

{% set iconClass = class ?? 'w-5 h-5' %}
{% set iconSize = size ?? 20 %}
{% set iconStroke = stroke ?? '2' %}

<svg class="{{ iconClass }}" width="{{ iconSize }}" height="{{ iconSize }}" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round" stroke-width="{{ iconStroke }}" aria-hidden="true">
    {% if name == 'moon' %}
        <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/>
    {% elseif name == 'sun' %}
        <circle cx="12" cy="12" r="4"/>
        <path d="M12 2v2"/><path d="M12 20v2"/>
        <path d="m4.93 4.93 1.41 1.41"/><path d="m17.66 17.66 1.41 1.41"/>
        <path d="M2 12h2"/><path d="M20 12h2"/>
        <path d="m6.34 17.66-1.41 1.41"/><path d="m19.07 4.93-1.41 1.41"/>
    {% elseif name == 'user-check' %}
        <path d="M2 21a8 8 0 0 1 13.292-6"/>
        <circle cx="10" cy="8" r="5"/>
        <path d="m16 19 2 2 4-4"/>
    {% elseif name == 'file-text' %}
        <path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/>
        <path d="M14 2v4a2 2 0 0 0 2 2h4"/>
        <path d="M10 9H8"/><path d="M16 13H8"/><path d="M16 17H8"/>
    {% elseif name == 'sliders' %}
        <line x1="4" x2="4" y1="21" y2="14"/><line x1="4" x2="4" y1="6" y2="3"/>
        <line x1="12" x2="12" y1="21" y2="12"/><line x1="12" x2="12" y1="6" y2="3"/>
        <line x1="20" x2="20" y1="21" y2="16"/><line x1="20" x2="20" y1="8" y2="3"/>
        <line x1="1" x2="7" y1="14" y2="14"/><line x1="9" x2="15" y1="12" y2="12"/><line x1="17" x2="23" y1="16" y2="16"/>
    {% elseif name == 'image' %}
        <rect width="18" height="18" x="3" y="3" rx="2" ry="2"/>
        <circle cx="9" cy="9" r="2"/>
        <path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/>
    {% elseif name == 'zap' %}
        <path d="M4 14a1 1 0 0 1-.78-1.63l9.9-10.2a.5.5 0 0 1 .86.46l-1.92 6.02A1 1 0 0 0 13 10h7a1 1 0 0 1 .78 1.63l-9.9 10.2a.5.5 0 0 1-.86-.46l1.92-6.02A1 1 0 0 0 11 14z"/>
    {% elseif name == 'eye' %}
        <path d="M2.062 12.348a1 1 0 0 1 0-.696 10.75 10.75 0 0 1 19.876 0 1 1 0 0 1 0 .696 10.75 10.75 0 0 1-19.876 0"/>
        <circle cx="12" cy="12" r="3"/>
    {% elseif name == 'info' %}
        <circle cx="12" cy="12" r="10"/>
        <path d="M12 16v-4"/><path d="M12 8h.01"/>
    {% elseif name == 'alert-triangle' %}
        <path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/>
        <path d="M12 9v4"/><path d="M12 17h.01"/>
    {% elseif name == 'alert-circle' %}
        <circle cx="12" cy="12" r="10"/>
        <line x1="12" x2="12" y1="8" y2="12"/><line x1="12" x2="12.01" y1="16" y2="16"/>
    {% elseif name == 'check-circle' %}
        <path d="M21.801 10A10 10 0 1 1 17 3.335"/>
        <path d="m9 11 3 3L22 4"/>
    {% elseif name == 'trash-2' %}
        <path d="M3 6h18"/>
        <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6"/>
        <path d="M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/>
        <line x1="10" x2="10" y1="11" y2="17"/><line x1="14" x2="14" y1="11" y2="17"/>
    {% endif %}
</svg>
