{% extends '@Shared/email/layout/base.html.twig' %}

{% block title %}{{ gallery.title }} — Sélection terminée{% endblock %}

{% block content %}
<h1>Sélection terminée</h1>
<p>
    Le client a fini sa sélection sur la galerie <strong>{{ gallery.title }}</strong>.
</p>

{% if visitorName or visitorEmail %}
<table class="panel" role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%">
    <tr>
        <td class="panel-content">
            {% if visitorName %}<strong>{{ visitorName }}</strong><br>{% endif %}
            {% if visitorEmail %}{{ visitorEmail }}{% endif %}
        </td>
    </tr>
</table>
{% endif %}

<p>
    Sélection de ce visiteur :
    <strong>{{ countsByKind.favorite }}</strong> favori(s){% if countsByKind.print %},
    <strong>{{ countsByKind.print }}</strong> à imprimer{% endif %}{% if countsByKind.discard %},
    <strong>{{ countsByKind.discard }}</strong> à retirer{% endif %}.
</p>

{{ include('@Shared/email/partials/action_button.html.twig', {
    url: adminUrl,
    label: 'Voir la sélection dans l\'administration',
}) }}
{% endblock %}
