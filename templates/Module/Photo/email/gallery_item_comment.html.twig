{% extends '@Shared/email/layout/base.html.twig' %}

{% block content %}
<h1>Nouveau commentaire sur une photo</h1>
<p>Un visiteur vient de laisser un commentaire sur la galerie <strong>{{ gallery.title }}</strong>.</p>

<table class="panel" role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%">
    <tr>
        <td class="panel-content">
            {% if comment.visitorName %}<p style="margin:0 0 6px;"><strong>Visiteur :</strong> {{ comment.visitorName }}{% if comment.visitorEmail %} &lt;{{ comment.visitorEmail }}&gt;{% endif %}</p>{% endif %}
            <p style="margin:0;"><em>{{ comment.content|nl2br }}</em></p>
        </td>
    </tr>
</table>

{{ include('@Shared/email/partials/action_button.html.twig', {
    url: adminUrl,
    label: 'Voir dans l''admin',
}) }}
{% endblock %}
