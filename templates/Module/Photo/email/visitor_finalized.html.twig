{% extends '@Shared/email/layout/base.html.twig' %}

{% block title %}Confirmation de votre sélection — {{ gallery.title }}{% endblock %}

{% block content %}
<h1>Merci pour votre sélection !</h1>

{% if visitorName %}<p>Bonjour {{ visitorName }},</p>{% endif %}

<p>
    Nous avons bien reçu votre sélection sur la galerie <strong>{{ gallery.title }}</strong>.
    Le photographe va prendre contact avec vous prochainement pour la suite.
</p>

<p>
    Vous pouvez consulter votre sélection à tout moment via le lien ci-dessous (mais elle ne pourra plus être modifiée
    sauf si le photographe rouvre la galerie).
</p>

{{ include('@Shared/email/partials/action_button.html.twig', {
    url: galleryUrl,
    label: 'Voir ma galerie',
}) }}

<p style="color: #888; font-size: 12px; margin-top: 32px;">
    — {{ siteName }}
</p>
{% endblock %}
