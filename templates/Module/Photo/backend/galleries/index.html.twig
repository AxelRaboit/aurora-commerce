{% extends '@Core/backend/layout.html.twig' %}

{% block title %}{{ 'backend.nav.galleries'|trans }} - {{ parent() }}{% endblock %}

{% block page_header_slot %}
    {{ include('@Shared/components/page_header.html.twig', {
        crumbs: [
            {label: 'backend.modules.photo'|trans, href: path('backend_galleries')},
            {label: 'backend.nav.galleries'|trans},
        ],
    }) }}
{% endblock %}

{% block body %}
<div {{ vue_component('photo/backend/galleries/GalleriesApp', {
    galleries: galleries,
    search: search,
    listPath: listPath,
    createPath: createPath,
    updatePath: updatePath,
    deletePath: deletePath,
    editPath: editPath,
    crmEnabled: crmEnabled,
    contactsSearchPath: contactsSearchPath,
}) }} class="flex-1 min-w-0"></div>
{% endblock %}
