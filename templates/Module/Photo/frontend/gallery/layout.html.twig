<!DOCTYPE html>
<html lang="{{ app.request.locale|default('fr') }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="robots" content="noindex,nofollow">
    <title>{% block title %}{{ gallery.title }}{% endblock %} — {{ siteName }}</title>
    {% if siteFaviconUrl %}<link rel="icon" href="{{ siteFaviconUrl }}">{% else %}<link rel="icon" type="image/svg+xml" href="/favicon.svg">{% endif %}
    {{ include('@Shared/components/theme_script.html.twig', {colorScheme: true}) }}
    {{ vite_entry_link_tags('app') }}
    {{ vite_entry_link_tags('flash') }}
    {{ include('@Shared/components/primary_color_style.html.twig') }}
    {{ vite_entry_script_tags('app') }}
    {{ vite_entry_script_tags('flash') }}
    {{ vite_entry_script_tags('theme') }}
    {{ vite_entry_script_tags('guest') }}
    <script>window.__flash__ = {{ app.flashes|json_encode|raw }};</script>
</head>
<body class="bg-bg text-primary min-h-screen">
{% block body %}{% endblock %}
</body>
</html>
