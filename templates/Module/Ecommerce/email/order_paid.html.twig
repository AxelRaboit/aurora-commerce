{% extends '@Shared/email/layout/base.html.twig' %}

{% block title %}{{ 'ecommerce.mail.paid.subject'|trans }}{% endblock %}

{% block content %}
<h1>{{ 'ecommerce.mail.paid.heading'|trans }}</h1>
<p>{{ 'ecommerce.mail.paid.greeting'|trans({'{name}': order.name}) }}</p>
<p>{{ 'ecommerce.mail.paid.intro'|trans({'{number}': order.number, '{siteName}': siteName ?? 'Aurora'}) }}</p>

<table class="panel" role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%">
    <tr>
        <td class="panel-content">
            <p style="margin:0 0 6px;"><strong>{{ 'ecommerce.mail.common.order'|trans }} :</strong> {{ order.number }}</p>
            <p style="margin:0 0 12px;"><strong>{{ 'ecommerce.mail.common.total'|trans }} :</strong> {{ (order.totalCents / 100)|number_format(2, ',', ' ') }} {{ currency.symbol }}</p>
            <table cellpadding="0" cellspacing="0" border="0" width="100%" style="font-size:14px;">
                {% for line in order.lines %}
                    <tr>
                        <td style="padding:4px 0;">{{ line.titleSnapshot }} × {{ line.quantity }}</td>
                        <td style="padding:4px 0; text-align:right;">{{ (line.subtotalCents / 100)|number_format(2, ',', ' ') }} {{ currency.symbol }}</td>
                    </tr>
                {% endfor %}
            </table>
        </td>
    </tr>
</table>

{{ include('@Shared/email/partials/action_button.html.twig', {
    url: orderUrl,
    label: 'ecommerce.mail.common.cta_view'|trans,
}) }}

<p class="muted" style="margin-top:24px;">{{ 'ecommerce.mail.paid.support'|trans }}</p>
{% endblock %}
