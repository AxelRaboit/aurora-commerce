{% extends '@Shared/email/layout/base.html.twig' %}

{% block title %}{{ 'ecommerce.mail.refund.subject'|trans }}{% endblock %}

{% block content %}
<h1>{{ 'ecommerce.mail.refund.heading'|trans }}</h1>
<p>{{ 'ecommerce.mail.refund.greeting'|trans({'{name}': order.name}) }}</p>
<p>
    {% if isFullRefund %}
        {{ 'ecommerce.mail.refund.intro_full'|trans({
            '{number}': order.number,
            '{siteName}': siteName ?? 'Aurora',
        }) }}
    {% else %}
        {{ 'ecommerce.mail.refund.intro_partial'|trans({
            '{number}': order.number,
            '{siteName}': siteName ?? 'Aurora',
        }) }}
    {% endif %}
</p>

<table class="panel" role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%">
    <tr>
        <td class="panel-content">
            <p style="margin:0 0 6px;">
                <strong>{{ 'ecommerce.mail.refund.order'|trans }} :</strong> {{ order.number }}
            </p>
            <p style="margin:0 0 6px;">
                <strong>{{ 'ecommerce.mail.refund.amount'|trans }} :</strong>
                {{ (amountCents / 100)|number_format(2, ',', ' ') }} {{ currency.symbol }}
            </p>
            <p style="margin:0;">
                <strong>{{ 'ecommerce.mail.refund.original_total'|trans }} :</strong>
                {{ (order.totalCents / 100)|number_format(2, ',', ' ') }} {{ currency.symbol }}
            </p>
        </td>
    </tr>
</table>

<p>{{ 'ecommerce.mail.refund.delay'|trans }}</p>

{{ include('@Shared/email/partials/action_button.html.twig', {
    url: orderUrl,
    label: 'ecommerce.mail.refund.cta'|trans,
}) }}

<p class="muted" style="margin-top:24px;">{{ 'ecommerce.mail.refund.support'|trans }}</p>
{% endblock %}
