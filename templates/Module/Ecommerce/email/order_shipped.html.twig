{% extends '@Shared/email/layout/base.html.twig' %}

{% block title %}{{ 'ecommerce.mail.shipped.subject'|trans }}{% endblock %}

{% block content %}
<h1>{{ 'ecommerce.mail.shipped.heading'|trans }}</h1>
<p>{{ 'ecommerce.mail.shipped.greeting'|trans({'{name}': order.name}) }}</p>
<p>{{ 'ecommerce.mail.shipped.intro'|trans({'{number}': order.number}) }}</p>

{% if order.requiresShipping %}
<table class="panel" role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%">
    <tr>
        <td class="panel-content">
            <p style="margin:0 0 6px;"><strong>{{ 'ecommerce.mail.common.shipping_address'|trans }} :</strong></p>
            <p style="margin:0;">{{ order.addressLine1 }}{% if order.addressLine2 %}, {{ order.addressLine2 }}{% endif %}</p>
            <p style="margin:0;">{{ order.postalCode }} {{ order.city }} ({{ order.countryEnum }})</p>
        </td>
    </tr>
</table>
{% endif %}

{{ include('@Shared/email/partials/action_button.html.twig', {
    url: orderUrl,
    label: 'ecommerce.mail.common.cta_view'|trans,
}) }}
{% endblock %}
