{% extends '@Shared/email/layout/base.html.twig' %}

{% block title %}{{ 'ecommerce.mail.cancelled.subject'|trans }}{% endblock %}

{% block content %}
<h1>{{ 'ecommerce.mail.cancelled.heading'|trans }}</h1>
<p>{{ 'ecommerce.mail.cancelled.greeting'|trans({'{name}': order.name}) }}</p>
<p>
    {% if refunded %}
        {{ 'ecommerce.mail.cancelled.intro_refunded'|trans({'{number}': order.number, '{siteName}': siteName ?? 'Aurora'}) }}
    {% else %}
        {{ 'ecommerce.mail.cancelled.intro'|trans({'{number}': order.number, '{siteName}': siteName ?? 'Aurora'}) }}
    {% endif %}
</p>

{% if refunded %}
<p>{{ 'ecommerce.mail.cancelled.refund_delay'|trans }}</p>
{% endif %}

<p class="muted" style="margin-top:24px;">{{ 'ecommerce.mail.cancelled.support'|trans }}</p>
{% endblock %}
