{% extends '@Core/admin/layout.html.twig' %}

{% block title %}{{ 'admin.nav.sitemap'|trans }} - {{ parent() }}{% endblock %}

{% block page_header_slot %}
    {{ include('@Shared/components/page_header.html.twig', {
        crumbs: [
            {label: 'admin.nav.sitemap'|trans},
        ],
    }) }}
{% endblock %}

{% block body %}
<div {{ vue_component('editorial/admin/SitemapApp', {
    stats: stats,
    invalidatePath: path('backend_sitemap_invalidate'),
    sitemapUrl: path('frontend_sitemap'),
}) }} class="flex-1 min-w-0"></div>
{% endblock %}
