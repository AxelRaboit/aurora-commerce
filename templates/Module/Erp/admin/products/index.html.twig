{% extends '@Core/admin/layout.html.twig' %}

{% block title %}{{ 'backend.nav.products'|trans }} - {{ parent() }}{% endblock %}

{% block page_header_slot %}
    {{ include('@Shared/components/page_header.html.twig', {
        crumbs: [
            {label: 'backend.modules.erp'|trans, href: path('backend_erp_products')},
            {label: 'backend.nav.products'|trans},
        ],
    }) }}
{% endblock %}

{% block body %}
<div {{ vue_component('erp/admin/products/ProductsApp', {
    products: products,
    search: search,
    createPath: createPath,
    updatePath: updatePath,
    deletePath: deletePath,
    showPath: showPath,
    listPath: path('backend_erp_products_list'),
}) }} class="flex-1 min-w-0"></div>
{% endblock %}
