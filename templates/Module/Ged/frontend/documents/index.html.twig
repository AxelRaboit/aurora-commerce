{% extends '@Frontend/layout.html.twig' %}

{% block title %}{{ 'ged.frontend.documents.title'|trans }}{% endblock %}

{% block body %}
<div class="max-w-4xl mx-auto px-4 py-10 space-y-10">
    <h1 class="text-2xl font-bold text-primary">{{ 'ged.frontend.documents.title'|trans }}</h1>

    {% for group in groups %}
    <section>
        <h2 class="text-base font-semibold text-secondary uppercase tracking-wide mb-3">{{ group.category.name }}</h2>
        {% if group.category.description %}
            <p class="text-sm text-muted mb-4">{{ group.category.description }}</p>
        {% endif %}
        <ul class="space-y-2">
            {% for doc in group.documents %}
            <li class="flex items-start gap-3 p-4 bg-surface border border-line rounded-lg hover:bg-surface-2/40 transition-colors">
                <div class="flex-1 min-w-0">
                    <p class="font-medium text-primary">{{ doc.title }}</p>
                    {% if doc.description %}
                        <p class="text-sm text-secondary mt-0.5">{{ doc.description }}</p>
                    {% endif %}
                    {% if doc.tags|length > 0 %}
                    <div class="flex flex-wrap gap-1 mt-1.5">
                        {% for tag in doc.tags %}
                        <span class="text-xs px-1.5 py-0.5 rounded-full border border-line/60">{{ tag.name }}</span>
                        {% endfor %}
                    </div>
                    {% endif %}
                </div>
                {% if doc.fileUrl %}
                <a href="{{ doc.fileUrl }}" target="_blank" rel="noopener" download
                   class="shrink-0 text-sm text-accent hover:underline flex items-center gap-1 mt-0.5">
                    {{ 'shared.common.download'|trans }}
                </a>
                {% endif %}
            </li>
            {% endfor %}
        </ul>
    </section>
    {% endfor %}

    {% if uncategorized|length > 0 %}
    <section>
        <h2 class="text-base font-semibold text-secondary uppercase tracking-wide mb-3">{{ 'backend.ged.documents.noCategory'|trans }}</h2>
        <ul class="space-y-2">
            {% for doc in uncategorized %}
            <li class="flex items-start gap-3 p-4 bg-surface border border-line rounded-lg hover:bg-surface-2/40 transition-colors">
                <div class="flex-1 min-w-0">
                    <p class="font-medium text-primary">{{ doc.title }}</p>
                    {% if doc.description %}
                        <p class="text-sm text-secondary mt-0.5">{{ doc.description }}</p>
                    {% endif %}
                </div>
                {% if doc.fileUrl %}
                <a href="{{ doc.fileUrl }}" target="_blank" rel="noopener" download
                   class="shrink-0 text-sm text-accent hover:underline mt-0.5">
                    {{ 'shared.common.download'|trans }}
                </a>
                {% endif %}
            </li>
            {% endfor %}
        </ul>
    </section>
    {% endif %}

    {% if groups|length == 0 and uncategorized|length == 0 %}
    <p class="text-muted text-sm">{{ 'ged.frontend.documents.empty'|trans }}</p>
    {% endif %}
</div>
{% endblock %}
