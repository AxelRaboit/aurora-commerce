{% extends '@Core/backend/layout.html.twig' %}

{% block title %}{{ tiers.name }} - {{ 'backend.nav.tiers'|trans }} - {{ parent() }}{% endblock %}

{% block page_header_slot %}
    {{ include('@Shared/components/page_header.html.twig', {
        title: tiers.name,
        crumbs: [
            {label: 'backend.nav.sections.billing'|trans},
            {label: 'backend.nav.tiers'|trans, href: listPath},
            {label: tiers.name},
        ],
    }) }}
{% endblock %}

{% block body %}
<div {{ vue_component('billing/backend/tiers/TiersShowApp', {
    tiers: tiers,
    invoices: invoices,
    stats: stats,
    listPath: listPath,
    invoicesListPath: invoicesListPath,
    invoiceShowPath: invoiceShowPath,
    updatePath: updatePath,
    deletePath: deletePath,
    statusOptions: statusOptions,
}) }} class="flex-1 min-w-0"></div>
{% endblock %}
