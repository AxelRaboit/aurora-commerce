{% extends '@Core/admin/layout.html.twig' %}

{% block title %}{{ 'admin.modules.billing'|trans }} - {{ parent() }}{% endblock %}

{% block page_header_slot %}
    {{ include('@Shared/components/page_header.html.twig', {
        crumbs: [
            {label: 'admin.modules.billing'|trans, href: path('billing_invoices')},
            {label: 'admin.nav.dashboard'|trans},
        ],
    }) }}
{% endblock %}

{% block body %}
<div {{ vue_component('billing/admin/DashboardApp', {
    stats: stats,
    countsByStatus: countsByStatus,
    topSuppliers: topSuppliers,
    needsReview: needsReview,
    invoicesPath: invoicesPath,
    showPath: showPath,
    importPath: importPath,
    statusOptions: statusOptions,
}) }} class="flex-1 min-w-0"></div>
{% endblock %}
