{% extends '@Core/admin/layout.html.twig' %}

{% block title %}{{ 'admin.nav.suppliers'|trans }} - {{ parent() }}{% endblock %}

{% block page_header_slot %}
    {{ include('@Shared/components/page_header.html.twig', {
        crumbs: [
            {label: 'admin.modules.billing'|trans, href: path('billing_invoices')},
            {label: 'admin.nav.suppliers'|trans},
        ],
    }) }}
{% endblock %}

{% block body %}
<div {{ vue_component('billing/admin/SuppliersApp', {
    suppliers: suppliers,
    search: search,
    listPath: listPath,
    deletePath: deletePath,
    showPath: showPath,
}) }} class="flex-1 min-w-0"></div>
{% endblock %}
