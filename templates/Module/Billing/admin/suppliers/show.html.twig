{% extends '@Core/admin/layout.html.twig' %}

{% block title %}{{ supplier.name }} - {{ 'admin.nav.suppliers'|trans }} - {{ parent() }}{% endblock %}

{% block page_header_slot %}
    {{ include('@Shared/components/page_header.html.twig', {
        title: supplier.name,
        crumbs: [
            {label: 'admin.nav.suppliers'|trans, href: listPath},
            {label: supplier.name},
        ],
    }) }}
{% endblock %}

{% block body %}
<div {{ vue_component('billing/admin/SupplierShowApp', {
    supplier: supplier,
    invoices: invoices,
    stats: stats,
    listPath: listPath,
    invoicesListPath: invoicesListPath,
    invoiceShowPath: invoiceShowPath,
    updatePath: updatePath,
    deletePath: deletePath,
    statusOptions: statusOptions,
}) }} class="flex-1 min-w-0"></div>
{% endblock %}
