{% extends '@Core/admin/layout.html.twig' %}

{% block title %}{{ deal.name }} - {{ 'backend.nav.deals'|trans }} - {{ parent() }}{% endblock %}

{% block page_header_slot %}
    {{ include('@Shared/components/page_header.html.twig', {
        title: deal.name,
        crumbs: [
            {label: 'backend.modules.crm'|trans, href: path('backend_crm_contacts')},
            {label: 'backend.nav.deals'|trans, href: backPath},
            {label: deal.name},
        ],
    }) }}
{% endblock %}

{% block body %}
<div {{ vue_component('crm/admin/deals/DealDetailApp', {
    deal: deal,
    backPath: backPath,
    updatePath: updatePath,
    deletePath: deletePath,
    updateStagePath: updateStagePath,
}) }} class="flex-1 min-w-0"></div>
{% endblock %}
