{% extends '@Shared/email/layout/base.html.twig' %}

{% block content %}
<h1>{{ 'crm.mail.contact.heading'|trans }}</h1>
<p>{{ 'crm.mail.contact.intro'|trans }}</p>

<table class="panel" role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%">
    <tr>
        <td class="panel-content">
            <p style="margin:0 0 6px;"><strong>{{ 'crm.mail.contact.name'|trans }} :</strong> {{ contact.fullName }}</p>
            {% if contact.email %}<p style="margin:0 0 6px;"><strong>{{ 'crm.mail.contact.email'|trans }} :</strong> {{ contact.email }}</p>{% endif %}
            {% if contact.phone %}<p style="margin:0 0 6px;"><strong>{{ 'crm.mail.contact.phone'|trans }} :</strong> {{ contact.phone }}</p>{% endif %}
            {% if contact.company %}<p style="margin:0;"><strong>{{ 'crm.mail.contact.company'|trans }} :</strong> {{ contact.company.name }}</p>{% endif %}
        </td>
    </tr>
</table>
{% endblock %}
