{% extends '@Core/backend/layout.html.twig' %}

{% block title %}{{ 'assistant.title'|trans }} - {{ parent() }}{% endblock %}

{% block page_header_slot %}
    {{ include('@Shared/components/page_header.html.twig', {
        crumbs: [
            {label: 'backend.nav.sections.assistant'|trans},
            {label: 'assistant.title'|trans},
        ],
    }) }}
{% endblock %}

{% block body %}
<div {{ vue_component('assistant/backend/AssistantApp', {
    conversations: conversations,
    model: model,
    listPath: listPath,
    showPath: showPath,
    createPath: createPath,
    sendPath: sendPath,
    confirmToolPath: confirmToolPath,
    renamePath: renamePath,
    deletePath: deletePath,
}) }} class="flex-1 min-w-0"></div>
{% endblock %}
