<!DOCTYPE html>
<html lang="{{ app.request.locale }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="generator" content="Aurora by axelraboit">
    <!-- Built with Aurora · © axelraboit · https://github.com/AxelRaboit -->
    <title>{% block title %}{{ siteName }}{% endblock %}</title>
    {% if siteFaviconUrl %}
        <link rel="icon" href="{{ siteFaviconUrl }}">
    {% else %}
        <link rel="icon" type="image/svg+xml" href="/favicon.svg">
    {% endif %}
    {{ include('@Shared/components/theme_script.html.twig', {colorScheme: true, sidemenu: true}) }}
    {% block stylesheets %}
        {{ vite_entry_link_tags('app') }}
        {{ vite_entry_link_tags('flash') }}
    {% endblock %}
    {# Inject after Vite stylesheets so the runtime --th-accent-* override wins over the defaults baked into app.css. #}
    {{ include('@Shared/components/primary_color_style.html.twig') }}
    <script>
        window.__flash__ = {{ app.flashes|json_encode|raw }};
        window.__privileges__ = {{ app.user.privileges|json_encode|raw }};
        window.__isDev__ = {{ is_granted('ROLE_DEV') ? 'true' : 'false' }};
        window.__isAdmin__ = {{ is_granted('ROLE_ADMIN') ? 'true' : 'false' }};
        window.__auroraConfig = window.__auroraConfig || {};
        window.__auroraConfig.colorPickerPresets = {{ app_color_presets()|json_encode|raw }};
    </script>
    {% block javascripts %}
        {{ vite_entry_script_tags('app') }}
        {{ vite_entry_script_tags('flash') }}
    {% endblock %}
</head>
<body class="transition-colors duration-200">

{{ include('@Shared/components/app_loader.html.twig') }}

<div class="min-h-screen bg-bg">

    <div {{ vue_component('core/backend/sidemenu/AppSidemenu', {
        navSections: sidemenu_nav_sections(),
        navSectionAliases: nav_section_aliases(),
        navItemAliases: nav_item_aliases(),
        userName: app.user.name,
        userEmail: app.user.email,
        userPhotoUrl: aurora_profile_photo_url(app.user) ?? '',
        activeRoute: app.request.attributes.get('_route'),
        logoutCsrf: csrf_token('logout'),
        frontPath: path('frontend_root'),
        hasEnabledFronts: has_enabled_fronts(),
        profilePath: path('backend_profile'),
        sidemenuPreferencesPath: path('backend_profile_sidemenu'),
        logoutPath: path('backend_logout'),
        locale: app.request.locale,
        mailpitUrl: app.environment == 'dev' ? 'http://127.0.0.1:8025' : '',
        siteName: siteName ?? '',
        siteLogoUrl: siteLogoUrl ?? '',
        appVersion: appVersion is defined ? appVersion : '',
        searchPath: path('backend_search'),
        notificationsListPath: path('backend_notifications_list'),
        notificationsMarkReadPath: path('backend_notifications_mark_read', {id: '__id__'}),
        notificationsMarkAllReadPath: path('backend_notifications_mark_all_read'),
        notificationsDeletePath: path('backend_notifications_delete', {id: '__id__'}),
        notificationsDeleteAllPath: path('backend_notifications_delete_all'),
    }) }}></div>

    <div id="main-content" class="flex-1 flex flex-col min-h-screen transition-colors duration-200 pt-14 lg:pt-0">

        {% block page_header_slot %}{% endblock %}

        {% if app.environment == 'dev' and aurora_pending_migrations() > 0 %}
            {% embed '@Shared/components/app_message.html.twig' with {variant: 'warning', strip: true, icon: 'database'} %}
                {% block content %}
                    {{ 'backend.migrations.pending.banner'|trans({'{count}': aurora_pending_migrations()}) }}
                {% endblock %}
                {% block actions %}
                    <code class="ml-2 font-mono text-xs px-1.5 py-0.5 rounded bg-warning/10 border border-warning/30">make migrate</code>
                {% endblock %}
            {% endembed %}
        {% endif %}

        {% if app.environment == 'dev' %}
            {% for warning in aurora_dev_warnings() %}
                {% set variant = warning.level == 'warning' ? 'warning' : 'info' %}
                {% set icon = warning.level == 'warning' ? 'triangle-alert' : 'info' %}
                {% embed '@Shared/components/app_message.html.twig' with {variant: variant, strip: true, icon: icon} %}
                    {% block content %}{{ warning.message }}{% endblock %}
                    {% block actions %}
                        <code class="ml-2 font-mono text-xs px-1.5 py-0.5 rounded bg-current/10 border border-current/30 opacity-70">{{ warning.fix }}</code>
                    {% endblock %}
                {% endembed %}
            {% endfor %}
        {% endif %}

        {% if is_granted('IS_IMPERSONATOR') %}
            {% embed '@Shared/components/app_message.html.twig' with {variant: 'warning', strip: true, icon: 'user-check'} %}
                {% block content %}{{ 'backend.impersonation.banner'|trans({'{name}': app.user.name}) }}{% endblock %}
                {% block actions %}
                    {{ include('@Shared/components/app_link.html.twig', {
                        href: path('backend_dashboard', {_switch_user: '_exit'}),
                        variant: 'inherit',
                        extraClass: 'ml-2 font-medium',
                        label: 'backend.impersonation.leave'|trans,
                    }) }}
                {% endblock %}
            {% endembed %}
        {% endif %}

        <main class="flex-1 px-4 sm:px-6 lg:px-8 py-8">
            {% block body %}{% endblock %}
        </main>
    </div>
</div>

</body>
</html>
