<!DOCTYPE html>
<html lang="{{ app.request.locale }}">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <meta name="generator" content="Aurora by axelraboit">
        <!-- Built with Aurora · © axelraboit · https://github.com/AxelRaboit -->
        <title>{% block title %}{{ siteName }}{% endblock %}</title>
        {% if siteFaviconUrl %}
            <link rel="icon" href="{{ siteFaviconUrl }}">
        {% else %}
            <link rel="icon" type="image/svg+xml" href="/favicon.svg">
        {% endif %}
        <link rel="preconnect" href="https://fonts.bunny.net">
        <link rel="stylesheet" href="https://fonts.bunny.net/css?family=inter:400,500,600,700&display=swap">
        {{ include('@Shared/components/theme_script.html.twig', {colorScheme: true}) }}
        {{ vite_entry_link_tags('app') }}
        {{ vite_entry_link_tags('flash') }}
        {# Inject after Vite stylesheets so the runtime --th-accent-* override wins over the defaults baked into app.css. #}
        {{ include('@Shared/components/primary_color_style.html.twig') }}
        {{ vite_entry_script_tags('app') }}
        {{ vite_entry_script_tags('flash') }}
        {{ vite_entry_script_tags('theme') }}
        {{ vite_entry_script_tags('guest') }}
        <script>window.__flash__ = {{ app.flashes|json_encode|raw }};</script>
    </head>
    <body class="transition-colors duration-200">

        <div id="guest-toggle"></div>

        {% set hero_content %}{% block hero %}{% endblock %}{% endset %}
        {% set form_content %}{% block content %}{% endblock %}{% endset %}
        {% set form_title %}{% block form_title %}{% endblock %}{% endset %}
        {% set form_subtitle %}{% block form_subtitle %}{% endblock %}{% endset %}
        {% set form_icon %}{% block form_icon %}{% endblock %}{% endset %}
        {% set form_icon = form_icon|trim %}

        {% set form_card %}
            <div class="w-full bg-surface border border-line shadow-md rounded-xl overflow-hidden {% if hero_content|trim %}{% else %}sm:max-w-md{% endif %}">
                {% if form_title|trim or form_icon %}
                    <div class="relative h-20 bg-linear-to-br from-accent-400 via-accent-500 to-accent-700">
                        <div class="absolute inset-0 opacity-25" style="background-image: radial-gradient(circle at 25% 20%, rgba(255,255,255,0.9) 0%, transparent 45%), radial-gradient(circle at 80% 80%, rgba(255,255,255,0.4) 0%, transparent 45%);"></div>
                        {% if form_icon %}
                            <div class="absolute inset-x-0 -bottom-6 flex justify-center">
                                <div class="w-12 h-12 rounded-2xl bg-surface border border-line shadow-md flex items-center justify-center text-accent-500">
                                    {{ include('@Shared/components/icon.html.twig', {name: form_icon, class: 'w-6 h-6'}) }}
                                </div>
                            </div>
                        {% endif %}
                    </div>
                {% endif %}
                <div class="px-6 pb-6 {% if form_icon %}pt-10{% elseif form_title|trim %}pt-5{% else %}pt-6{% endif %}">
                    {% if form_title|trim %}
                        <div class="text-center mb-5">
                            <h1 class="text-primary text-xl font-bold leading-tight">{{ form_title|raw }}</h1>
                            {% if form_subtitle|trim %}
                                <p class="text-muted text-sm mt-1">{{ form_subtitle|raw }}</p>
                            {% endif %}
                        </div>
                    {% endif %}
                    {{ form_content|raw }}
                </div>
            </div>
        {% endset %}

        {% if hero_content|trim %}
            <div class="flex min-h-screen items-center justify-center bg-bg px-4 py-12">
                <div class="w-full max-w-7xl grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">
                    <div>
                        {{ include('@Shared/components/app_logo.html.twig', {
                            gradientId: 'app-logo-hero',
                            href: path('backend_login'),
                            linkClass: 'inline-flex items-center gap-3 mb-8',
                            withText: true,
                            appVersion: appVersion ?? null,
                        }) }}
                        {{ hero_content|raw }}
                    </div>
                    <div class="flex flex-col items-center gap-3">
                        {{ form_card|raw }}
                        <p class="text-xs text-muted/40"><a href="https://github.com/AxelRaboit" target="_blank" rel="noopener" class="hover:text-muted/60 transition-colors">{{ 'shared.common.built_with'|trans }}</a></p>
                    </div>
                </div>
            </div>
        {% else %}
            <div class="flex min-h-screen flex-col items-center justify-center bg-bg px-4 py-12">
                {{ include('@Shared/components/app_logo.html.twig', {
                    gradientId: 'app-logo-stack',
                    href: path('backend_login'),
                    linkClass: 'flex flex-col items-center gap-2 mb-6',
                    withText: true,
                    textClass: 'text-primary font-bold text-2xl',
                    versionClass: 'text-xs text-secondary',
                    textLayout: 'contents',
                    appVersion: appVersion ?? null,
                }) }}
                {{ form_card|raw }}
                <p class="mt-3 text-xs text-muted/40"><a href="https://github.com/AxelRaboit" target="_blank" rel="noopener" class="hover:text-muted/60 transition-colors">{{ 'shared.common.built_with'|trans }}</a></p>
            </div>
        {% endif %}

    </body>
</html>
