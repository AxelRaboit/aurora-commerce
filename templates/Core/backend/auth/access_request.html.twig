{% extends '@Core/backend/base_guest.html.twig' %}

{% block title %}{{ 'backend.auth.access_request.title'|trans }} - {{ parent() }}{% endblock %}

{% block hero %}
    {% if accessRequestEnabled %}
        {{ include('@Shared/components/auth_hero.html.twig') }}
    {% endif %}
{% endblock %}

{% block form_icon %}user-check{% endblock %}
{% block form_title %}{{ 'backend.auth.access_request.title'|trans }}{% endblock %}

{% block content %}
    <div {{ vue_component('core/backend/auth/AccessRequestApp', {
        submitPath: path('backend_access_request'),
        loginPath: path('backend_login'),
        accessRequestEnabled: accessRequestEnabled,
        initialErrors: errors,
        values: {
            name: values.name ?? '',
            email: values.email ?? '',
            message: values.message ?? '',
        },
    }) }}></div>
{% endblock %}
