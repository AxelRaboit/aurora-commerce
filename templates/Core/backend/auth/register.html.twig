{% extends '@Core/backend/base_guest.html.twig' %}

{% block title %}{{ 'backend.auth.register.title'|trans }} - {{ parent() }}{% endblock %}

{% block hero %}
    {% if registrationEnabled %}
        {{ include('@Shared/components/auth_hero.html.twig') }}
    {% endif %}
{% endblock %}

{% block form_icon %}user-plus{% endblock %}
{% block form_title %}{{ 'backend.auth.register.title'|trans }}{% endblock %}
{% block form_subtitle %}{{ 'backend.auth.register.subtitle'|trans }}{% endblock %}

{% block content %}
    <div {{ vue_component('core/backend/auth/RegisterApp', {
        registerPath: path('backend_register'),
        loginPath: path('backend_login'),
        registrationEnabled: registrationEnabled,
        initialErrors: errors,
        values: {name: values.name ?? '', email: values.email ?? ''},
    }) }}></div>
{% endblock %}
