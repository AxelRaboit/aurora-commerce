{% extends '@Core/admin/layout.html.twig' %}

{% block title %}{{ 'admin.nav.themes'|trans }} - {{ parent() }}{% endblock %}

{% block page_header_slot %}
    {{ include('@Shared/components/page_header.html.twig', {
        crumbs: [
            {label: 'admin.nav.themes'|trans},
        ],
    }) }}
{% endblock %}

{% block body %}
<div {{ vue_component('core/admin/themes/ThemesApp', {
    themes: themes,
    activatePath: path('backend_themes_activate', {id: '__id__'}),
    updatePath: path('backend_themes_update', {id: '__id__'}),
    deletePath: path('backend_themes_delete', {id: '__id__'}),
    createPath: path('backend_themes_create'),
}) }} class="flex-1 min-w-0"></div>
{% endblock %}
