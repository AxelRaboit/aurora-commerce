{% extends '@Core/admin/base_guest.html.twig' %}

{% block title %}{{ 'admin.auth.access_request.title'|trans }} - {{ parent() }}{% endblock %}

{% block hero %}
    {% if accessRequestEnabled %}
        {{ include('@Shared/components/auth_hero.html.twig') }}
    {% endif %}
{% endblock %}

{% block content %}
    <div {{ vue_component('core/admin/auth/AccessRequestApp', {
        submitPath: path('admin_access_request'),
        loginPath: path('admin_login'),
        accessRequestEnabled: accessRequestEnabled,
        initialErrors: errors,
        values: {
            name: values.name ?? '',
            email: values.email ?? '',
            message: values.message ?? '',
        },
    }) }}></div>
{% endblock %}
