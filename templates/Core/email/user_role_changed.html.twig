{% extends '@Shared/email/layout/base.html.twig' %}

{% block content %}
<h1>{{ 'backend.mail.user.role_changed_heading'|trans }}</h1>
<p>{{ 'backend.mail.user.role_changed_intro'|trans({'{name}': user.name, '{siteName}': siteName}) }}</p>

<table class="panel" role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%">
    <tr>
        <td class="panel-content">
            <p style="margin:0;"><strong>{{ 'backend.mail.user.role_changed_label'|trans }} :</strong> {{ newRole }}</p>
        </td>
    </tr>
</table>

<p>{{ 'backend.mail.user.role_changed_outro'|trans }}</p>
{% endblock %}
