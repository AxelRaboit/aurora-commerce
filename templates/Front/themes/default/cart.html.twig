{% extends 'Front/themes/default/layout.html.twig' %}

{% block title %}{{ 'front.cart.title'|trans }} — {{ context.siteName }}{% endblock %}

{% block body %}
<div {{ vue_component('ecommerce/front/CartApp', {
    initialCart: cart,
    locale: locale,
    updatePath: path('frontend_cart_update', {locale: locale}),
    removePath: path('frontend_cart_remove', {locale: locale}),
    shopPath: path('frontend_shop_index', {locale: locale}),
    checkoutPath: path('frontend_checkout', {locale: locale}),
}) }}></div>
{% endblock %}
