{% extends 'Front/themes/default/layout.html.twig' %}

{% block title %}{{ 'front.shop.title'|trans }} — {{ context.siteName }}{% endblock %}

{% block body %}
    <section>
        <h1 class="text-3xl font-bold mb-6">{{ 'front.shop.title'|trans }}</h1>

        {% if listings|length == 0 %}
            <p class="text-muted">{{ 'front.shop.empty'|trans }}</p>
        {% else %}
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
                {% for listing in listings %}
                    <article class="bg-surface border border-line/60 rounded-xl overflow-hidden hover:border-accent transition-colors">
                        <a href="{{ path('front_shop_product', {locale: locale, slug: listing.slug}) }}" class="block">
                            {% if listing.displayImage %}
                                <div class="aspect-square bg-surface-2 overflow-hidden">
                                    <img
                                        src="{{ listing.displayImage.url }}"
                                        alt="{{ listing.displayImage.alt ?? listing.displayTitle }}"
                                        class="w-full h-full object-cover"
                                        loading="lazy"
                                    >
                                </div>
                            {% else %}
                                <div class="aspect-square bg-surface-2 flex items-center justify-center text-muted text-xs">
                                    {{ 'front.shop.no_image'|trans }}
                                </div>
                            {% endif %}
                            <div class="p-4 space-y-2">
                                <div class="flex items-start justify-between gap-2">
                                    <h2 class="text-lg font-semibold text-primary">{{ listing.displayTitle }}</h2>
                                    {% if listing.product.type == 'digital' %}
                                        <span class="shrink-0 inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-accent-500/15 text-accent-400">{{ 'front.shop.type.digital'|trans }}</span>
                                    {% elseif listing.product.type == 'service' %}
                                        <span class="shrink-0 inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-violet-500/15 text-violet-400">{{ 'front.shop.type.service'|trans }}</span>
                                    {% endif %}
                                </div>
                                {% if listing.product.price is not null %}
                                    <p class="text-base font-bold text-accent">
                                        {{ listing.product.price|number_format(2, ',', ' ') }} {{ listing.product.currencySymbol }}
                                    </p>
                                {% endif %}
                                {% if listing.product.stockTracked and not listing.product.inStock %}
                                    <p class="text-xs text-rose-400 font-medium">{{ 'front.shop.out_of_stock'|trans }}</p>
                                {% elseif listing.product.isLowStock %}
                                    <p class="text-xs text-amber-400">{{ 'front.shop.low_stock'|trans({'%count%': listing.product.stockQuantity}) }}</p>
                                {% endif %}
                            </div>
                        </a>
                    </article>
                {% endfor %}
            </div>

            {% if pagination.totalPages > 1 %}
                {{ include('Front/themes/default/_pagination.html.twig', {page: pagination.page, totalPages: pagination.totalPages, route: 'front_shop_index', params: {locale: locale}}) }}
            {% endif %}
        {% endif %}
    </section>
{% endblock %}
