{% extends 'Front/themes/default/layout.html.twig' %}

{% block title %}{{ 'frontend.account.orders'|trans }} — {{ context.siteName }}{% endblock %}

{% block body %}
<div {{ vue_component('ecommerce/front/AccountOrdersApp', {
    orders: orders,
    locale: locale,
    accountPath: path('frontend_account', {locale: locale}),
    shopPath: path('frontend_shop_index', {locale: locale}),
    orderPathBase: path('frontend_order_show', {locale: locale, token: '00000000000000000000000000000000'})|replace({'/00000000000000000000000000000000': ''}),
}) }}></div>
{% endblock %}
