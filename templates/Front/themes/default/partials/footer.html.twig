<footer
    class="border-t mt-12"
    style="background-color: var(--th-footer-bg, var(--th-surface)); border-color: var(--th-footer-border, var(--color-border));"
>
    <div class="w-full px-4 sm:px-6 lg:px-8 py-6 space-y-4 text-center text-xs"
        style="color: var(--th-footer-text, var(--th-muted));">
        {% set footerItems = menu_items('footer', locale) %}
        {% if footerItems %}
            {{ include('Front/themes/default/partials/menus/footer.html.twig', {items: footerItems}) }}
        {% endif %}
        <p>{{ themeContext.footerText(context.siteName) }}</p>
    </div>
</footer>
