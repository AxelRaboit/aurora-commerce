{% if items %}
    <ul class="flex flex-wrap items-center justify-center gap-x-6 gap-y-2">
        {% for item in items %}
            <li>
                <a
                    href="{{ item.url }}"
                    {% if item.openInNewTab %}target="_blank" rel="noopener"{% endif %}
                    class="text-xs transition-colors hover:opacity-80 {{ item.cssClass }}"
                    style="color: var(--th-footer-text, var(--th-muted));"
                >
                    {{ item.label }}
                </a>
                {% if item.children %}
                    <ul class="flex flex-wrap items-center gap-x-4 gap-y-1 mt-1 ml-2">
                        {% for child in item.children %}
                            <li>
                                <a
                                    href="{{ child.url }}"
                                    {% if child.openInNewTab %}target="_blank" rel="noopener"{% endif %}
                                    class="text-xs transition-colors hover:opacity-80 {{ child.cssClass }}"
                                    style="color: var(--th-footer-text, var(--th-muted));"
                                >
                                    {{ child.label }}
                                </a>
                            </li>
                        {% endfor %}
                    </ul>
                {% endif %}
            </li>
        {% endfor %}
    </ul>
{% endif %}
