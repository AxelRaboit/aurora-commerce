{% set ecommerceEnabled = is_ecommerce_front_enabled() %}
{% set cartCount = ecommerceEnabled ? cart_count() : 0 %}
{% if items or cartCount > 0 or app.user %}
    <div class="relative group">
        <button
            type="button"
            class="inline-flex items-center gap-2 px-2 py-1.5 rounded-md text-sm transition-colors hover:opacity-80 relative"
            style="color: var(--th-header-text, var(--th-primary));"
        >
            {{ include('@Shared/components/icon.html.twig', {name: 'user', size: 16}) }}
            <span class="hidden sm:inline">{{ app.user ? app.user.name : 'front.menu.account'|trans }}</span>
            <span data-cart-count class="inline-flex items-center justify-center min-w-5 h-5 px-1.5 rounded-full bg-accent text-white text-xs font-semibold tabular-nums" {% if cartCount == 0 %}style="display:none"{% endif %}>{{ cartCount }}</span>
            {{ include('@Shared/components/icon.html.twig', {name: 'chevron-down', size: 14, stroke: '2.5'}) }}
        </button>

        <div class="absolute right-0 top-full pt-1 min-w-56 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-100 z-50">
            <div class="rounded-lg border shadow-xl overflow-hidden" style="background-color: var(--th-surface); border-color: var(--color-border);">
                {% if ecommerceEnabled %}
                    <a href="{{ path('front_cart', {locale: locale}) }}"
                       class="flex items-center justify-between gap-3 px-4 py-2.5 text-sm transition-colors hover:opacity-80"
                       style="color: var(--th-primary);">
                        <span class="flex items-center gap-2">
                            {{ include('@Shared/components/icon.html.twig', {name: 'shopping-cart', size: 16}) }}
                            {{ 'front.cart.title'|trans }}
                        </span>
                        {% if cartCount > 0 %}
                            <span class="inline-flex items-center justify-center min-w-5 h-5 px-1.5 rounded-full bg-accent text-white text-xs font-semibold tabular-nums">{{ cartCount }}</span>
                        {% endif %}
                    </a>
                    {% if app.user %}
                        <a href="{{ path('front_account_orders', {locale: locale}) }}"
                           class="flex items-center gap-2 px-4 py-2.5 text-sm transition-colors hover:opacity-80"
                           style="color: var(--th-primary);">
                            {{ include('@Shared/components/icon.html.twig', {name: 'package', size: 16}) }}
                            {{ 'front.account.orders'|trans }}
                        </a>
                    {% endif %}
                {% endif %}
                {% if items %}
                    <div class="border-t" style="border-color: var(--color-border);"></div>
                    {% for item in items %}
                        {{ include('Front/themes/default/partials/menus/_dropdown_item.html.twig', {item: item}) }}
                    {% endfor %}
                {% endif %}
            </div>
        </div>
    </div>
{% endif %}
