{% extends 'Front/themes/default/layout.html.twig' %}

{% block title %}{{ 'front.order.title'|trans }} {{ order.number }} — {{ context.siteName }}{% endblock %}

{% block body %}
    <section class="space-y-6">
        <div class="text-center space-y-2">
            <div class="inline-flex w-16 h-16 rounded-full bg-emerald-500/15 text-emerald-400 items-center justify-center text-3xl">✓</div>
            <h1 class="text-3xl font-bold">{{ 'front.order.thanks'|trans }}</h1>
            <p class="text-muted">{{ 'front.order.confirmation_intro'|trans({'%number%': order.number}) }}</p>
        </div>

        <div class="bg-surface border border-line rounded-xl p-6">
            <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2 mb-4">
                <div>
                    <p class="text-xs text-muted uppercase tracking-wide">{{ 'front.order.number'|trans }}</p>
                    <p class="font-mono text-primary">{{ order.number }}</p>
                </div>
                <div>
                    <p class="text-xs text-muted uppercase tracking-wide">{{ 'front.order.status'|trans }}</p>
                    <p class="text-emerald-400 font-medium">{{ ('front.order.status_' ~ order.status)|trans }}</p>
                </div>
            </div>

            <table class="w-full text-sm border-t border-line">
                <thead>
                    <tr class="text-xs text-muted uppercase">
                        <th class="text-left py-2">{{ 'front.order.product'|trans }}</th>
                        <th class="text-right py-2">{{ 'front.order.qty'|trans }}</th>
                        <th class="text-right py-2">{{ 'front.order.subtotal'|trans }}</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-line">
                    {% for line in order.lines %}
                        <tr>
                            <td class="py-3">
                                <p class="text-primary">{{ line.title }}</p>
                                <p class="text-xs font-mono text-muted">{{ line.sku }}</p>
                            </td>
                            <td class="py-3 text-right text-secondary">{{ line.quantity }}</td>
                            <td class="py-3 text-right text-primary tabular-nums">{{ line.subtotal|number_format(2, ',', ' ') }} {{ line.currencySymbol }}</td>
                        </tr>
                    {% endfor %}
                </tbody>
                <tfoot>
                    <tr class="border-t border-line">
                        <td colspan="2" class="pt-3 text-right font-semibold">{{ 'front.cart.total'|trans }}</td>
                        <td class="pt-3 text-right text-xl font-bold text-accent">{{ order.total|number_format(2, ',', ' ') }} {{ order.currencySymbol }}</td>
                    </tr>
                </tfoot>
            </table>
        </div>

        <div class="bg-surface border border-line rounded-xl p-6 space-y-2">
            <h2 class="font-semibold text-primary mb-2">{{ 'front.checkout.shipping'|trans }}</h2>
            <p class="text-secondary text-sm">{{ order.name }}</p>
            <p class="text-secondary text-sm">{{ order.addressLine1 }}</p>
            {% if order.addressLine2 %}<p class="text-secondary text-sm">{{ order.addressLine2 }}</p>{% endif %}
            <p class="text-secondary text-sm">{{ order.postalCode }} {{ order.city }} ({{ order.country }})</p>
            <p class="text-muted text-sm pt-2">{{ order.email }}</p>
        </div>

        <div class="text-center">
            <a href="{{ path('front_shop_index', {locale: locale}) }}" class="text-accent hover:underline">{{ 'front.cart.continue_shopping'|trans }}</a>
        </div>
    </section>
{% endblock %}
