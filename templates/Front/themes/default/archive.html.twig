{% extends 'Front/themes/default/layout.html.twig' %}

{% block title %}{{ postType.label }} — {{ context.siteName }}{% endblock %}

{% block body %}
    <section>
        <h1 class="text-3xl font-bold mb-6">{{ postType.label }}</h1>
        {% if posts.items|length == 0 %}
            <p class="text-muted">{{ 'front.theme.no_content'|trans }}</p>
        {% else %}
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
                {% for post in posts.items %}
                    {{ include('Front/themes/default/_post_card.html.twig', {post: post, locale: locale}) }}
                {% endfor %}
            </div>
            {{ include('Front/themes/default/_pagination.html.twig', {page: posts.page, totalPages: posts.totalPages, route: 'editorial_archive', params: {locale: locale, postTypeSlug: postType.slug}}) }}
        {% endif %}
    </section>
{% endblock %}
