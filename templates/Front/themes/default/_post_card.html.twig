{% set translation = post.getTranslation(locale) %}
{% if translation and translation.slug %}
    {% set featured = post.featuredMedia %}
    <article class="bg-surface border border-line/60 rounded-xl overflow-hidden hover:border-accent transition-colors">
        <a href="{{ path('editorial_post', {locale: locale, postTypeSlug: post.postType.slug, slug: translation.slug}) }}" class="block">
            {% if featured %}
                <div class="aspect-video bg-surface-2 overflow-hidden">
                    <img
                        src="{{ featured.variantUrl('medium') ?? featured.publicUrl }}"
                        alt="{{ featured.alt ?? translation.title ?? '' }}"
                        class="w-full h-full object-cover"
                        style="object-position: {{ featured.focalPositionCss }}"
                        loading="lazy"
                    >
                </div>
            {% endif %}
            <div class="p-4 space-y-2">
                <h3 class="text-lg font-semibold text-primary">{{ translation.title ?? '(—)' }}</h3>
                {% if translation.metaDescription %}
                    <p class="text-sm text-muted line-clamp-3">{{ translation.metaDescription }}</p>
                {% endif %}
                {% if post.publishedAt %}
                    <time datetime="{{ post.publishedAt|date('c') }}" class="block text-xs text-muted">
                        {{ post.publishedAt|date('d/m/Y') }}
                    </time>
                {% endif %}
            </div>
        </a>
    </article>
{% endif %}
