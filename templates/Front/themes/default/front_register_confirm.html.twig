{% extends 'Front/themes/default/layout.html.twig' %}

{% block title %}{{ 'front.register.confirm_title'|trans }} — {{ context.siteName }}{% endblock %}

{% block body %}
    <div {{ vue_component('core/front/auth/RegisterConfirmApp', {
        loginPath: path('front_login', {locale: locale}),
        resendPath: path('front_resend_verification', {locale: locale}),
        pendingEmail: pendingEmail|default(''),
        resent: resent|default(false),
    }) }}></div>
{% endblock %}
