#!/usr/bin/env bash
set -euo pipefail

# ---------------------------------------------------------------------------
# Aurora — make-frontend
# Scaffolds a new custom frontend module (header, footer, layout, home page).
#
# Usage (from an aurora-client project):
#   bin/make-frontend <ModuleName> [--assets-dir <path>] [--templates-dir <path>]
#
# Examples:
#   bin/make-frontend Billing
#   bin/make-frontend Hr --assets-dir assets/client --templates-dir templates/Custom
# ---------------------------------------------------------------------------

RED='\033[0;31m'
GREEN='\033[0;32m'
CYAN='\033[0;36m'
YELLOW='\033[1;33m'
BOLD='\033[1m'
RESET='\033[0m'

# ── Argument parsing ────────────────────────────────────────────────────────
MODULE_NAME=""
ASSETS_DIR="assets/client"
TEMPLATES_DIR="templates/Custom"

while [[ $# -gt 0 ]]; do
    case $1 in
        --assets-dir)   ASSETS_DIR="$2";    shift 2 ;;
        --templates-dir) TEMPLATES_DIR="$2"; shift 2 ;;
        -*) echo -e "${RED}Unknown option: $1${RESET}"; exit 1 ;;
        *)  MODULE_NAME="$1"; shift ;;
    esac
done

if [[ -z "$MODULE_NAME" ]]; then
    echo -e "${RED}Error: module name is required.${RESET}"
    echo "Usage: bin/make-frontend <ModuleName>"
    exit 1
fi

# Derive lowercase route prefix (e.g. Billing → billing)
MODULE_SLUG=$(echo "$MODULE_NAME" | tr '[:upper:]' '[:lower:]')

# ── Destination paths ───────────────────────────────────────────────────────
VUE_DIR="${ASSETS_DIR}/Module/${MODULE_NAME}/frontend"
TPL_DIR="${TEMPLATES_DIR}/${MODULE_NAME}/frontend"
HEADER_VUE="${VUE_DIR}/${MODULE_NAME}HeaderApp.vue"
FOOTER_VUE="${VUE_DIR}/${MODULE_NAME}FooterApp.vue"
LAYOUT_TWIG="${TPL_DIR}/layout.html.twig"
HOME_TWIG="${TPL_DIR}/home.html.twig"

echo -e "${CYAN}${BOLD}Scaffolding frontend module: ${MODULE_NAME}${RESET}"
echo ""

# ── Guard against overwrite ─────────────────────────────────────────────────
for f in "$HEADER_VUE" "$FOOTER_VUE" "$LAYOUT_TWIG" "$HOME_TWIG"; do
    if [[ -f "$f" ]]; then
        echo -e "${YELLOW}Warning: $f already exists, skipping.${RESET}"
    fi
done

mkdir -p "$VUE_DIR" "$TPL_DIR"

# ── Header Vue ──────────────────────────────────────────────────────────────
if [[ ! -f "$HEADER_VUE" ]]; then
cat > "$HEADER_VUE" << 'VUEOF'
<script setup>
import { computed, ref, onMounted, onBeforeUnmount } from "vue";
import { useI18n } from "vue-i18n";
import { ChevronDown, User } from "lucide-vue-next";
import LocaleSwitcher from "@editorial/frontend/LocaleSwitcher.vue";

const { t } = useI18n();

const props = defineProps({
    locale: { type: String, required: true },
    siteName: { type: String, required: true },
    homePath: { type: String, required: true },
    headerLogoUrl: { type: String, default: "" },
    siteLogoUrl: { type: String, default: "" },
    headerCustomText: { type: String, default: "" },
    currentUser: { type: Object, default: null },
    accountMenuItems: { type: Array, default: () => [] },
    localeSwitcher: { type: Object, default: () => ({ enabled: false, locales: [] }) },
    loginPath: { type: String, default: "" },
    logoutPath: { type: String, default: "" },
});

const logoUrl = computed(() => props.headerLogoUrl || props.siteLogoUrl);
const showAccountMenu = computed(() => props.accountMenuItems.length > 0 || props.currentUser);

const accountOpen = ref(false);
const accountRef = ref(null);

function toggleAccount() {
    accountOpen.value = !accountOpen.value;
}

function onClickOutside(event) {
    if (accountRef.value && !accountRef.value.contains(event.target)) {
        accountOpen.value = false;
    }
}

onMounted(() => document.addEventListener("click", onClickOutside));
onBeforeUnmount(() => document.removeEventListener("click", onClickOutside));
</script>

<template>
    <header
        class="border-b"
        style="background-color: var(--th-header-bg, var(--th-surface)); border-color: var(--th-header-border, var(--color-border)); color: var(--th-header-text, var(--th-primary));"
    >
        <div class="w-full px-4 sm:px-6 lg:px-8 py-4 flex items-center gap-6 flex-wrap">
            <a :href="homePath" class="flex items-center gap-2 text-lg" style="color: var(--th-header-text, var(--th-primary));">
                <img v-if="logoUrl" :src="logoUrl" :alt="siteName" class="h-8 w-8 object-cover rounded-xl shrink-0">
                <span>{{ headerCustomText || siteName }}</span>
            </a>

            <div class="ml-auto flex items-center gap-2 text-sm">
                <div v-if="showAccountMenu" ref="accountRef" class="relative">
                    <button
                        type="button"
                        class="inline-flex items-center gap-2 px-2 py-1.5 rounded-md text-sm transition-colors hover:opacity-80 relative"
                        style="color: var(--th-header-text, var(--th-primary));"
                        v-on:click.stop="toggleAccount"
                    >
                        <User class="w-4 h-4" :stroke-width="2" />
                        <span class="hidden sm:inline">{{ currentUser ? currentUser.name : t('frontend.menu.account') }}</span>
                        <ChevronDown class="w-3.5 h-3.5" :stroke-width="2.5" />
                    </button>
                    <div v-if="accountOpen" class="absolute right-0 top-full mt-1 min-w-56 z-50">
                        <div class="rounded-lg border shadow-xl overflow-hidden" style="background-color: var(--th-surface); border-color: var(--color-border);">
                            <component
                                :is="item.targetType === 'frontend_logout' ? 'form' : 'a'"
                                v-for="item in accountMenuItems"
                                :key="item.id"
                                :method="item.targetType === 'frontend_logout' ? 'POST' : null"
                                :action="item.targetType === 'frontend_logout' ? item.url : null"
                                :href="item.targetType === 'frontend_logout' ? null : item.url"
                                class="block px-4 py-2 text-sm transition-colors hover:bg-surface-2"
                                style="color: var(--th-primary);"
                            >
                                <button v-if="item.targetType === 'frontend_logout'" type="submit" class="w-full text-left" style="color: var(--th-primary);">{{ item.label }}</button>
                                <template v-else>{{ item.label }}</template>
                            </component>
                            <template v-if="!accountMenuItems.length">
                                <form v-if="currentUser && logoutPath" :action="logoutPath" method="post">
                                    <button type="submit" class="w-full text-left block px-4 py-2 text-sm hover:bg-surface-2" style="color: var(--th-primary);">{{ t('frontend.menu.logout') }}</button>
                                </form>
                                <a v-else-if="!currentUser && loginPath" :href="loginPath" class="block px-4 py-2 text-sm hover:bg-surface-2" style="color: var(--th-primary);">{{ t('frontend.menu.login') }}</a>
                            </template>
                        </div>
                    </div>
                </div>
            </div>

            <LocaleSwitcher v-if="localeSwitcher.enabled" :current-locale="locale" :locales="localeSwitcher.locales" />
        </div>
    </header>
</template>
VUEOF
    echo -e "  ${GREEN}+${RESET} ${HEADER_VUE}"
fi

# ── Footer Vue ──────────────────────────────────────────────────────────────
if [[ ! -f "$FOOTER_VUE" ]]; then
cat > "$FOOTER_VUE" << 'VUEOF'
<script setup>
defineProps({
    footerText: { type: String, default: "" },
});
</script>

<template>
    <footer class="border-t border-line mt-auto">
        <div class="max-w-5xl mx-auto px-4 py-4 text-center text-xs text-muted">
            {{ footerText }}
        </div>
    </footer>
</template>
VUEOF
    echo -e "  ${GREEN}+${RESET} ${FOOTER_VUE}"
fi

# ── Layout Twig ─────────────────────────────────────────────────────────────
if [[ ! -f "$LAYOUT_TWIG" ]]; then
cat > "$LAYOUT_TWIG" << TWIGEOF
{% extends 'Front/themes/default/layout.html.twig' %}

{% block frontend_header %}
{% set localeFlagCodes = {fr: 'fr', en: 'gb', es: 'es', de: 'de', it: 'it', pt: 'pt', nl: 'nl'} %}
{% set localeNames = {fr: 'Français', en: 'English', es: 'Español', de: 'Deutsch', it: 'Italiano', pt: 'Português', nl: 'Nederlands'} %}
{% set moduleLocales = [] %}
{% for loc in context.activeLocales %}
    {% set moduleLocales = moduleLocales|merge([{
        code: loc.code,
        name: localeNames[loc.code] ?? loc.code|upper,
        flagCode: localeFlagCodes[loc.code] ?? loc.code,
        url: path('${MODULE_SLUG}_front_home', {locale: loc.code}),
    }]) %}
{% endfor %}
<div {{ vue_component('${MODULE_SLUG}/frontend/${MODULE_NAME}HeaderApp', {
    locale: locale,
    siteName: context.siteName,
    homePath: path('${MODULE_SLUG}_front_home', {locale: locale}),
    headerLogoUrl: themeContext.headerLogoUrl() ?? '',
    siteLogoUrl: siteLogoUrl ?? '',
    headerCustomText: themeContext.headerCustomText() ?? '',
    currentUser: app.user ? {name: app.user.name} : null,
    accountMenuItems: menu_items('account', locale),
    loginPath: path('frontend_login', {locale: locale}),
    logoutPath: path('frontend_logout', {locale: locale}),
    localeSwitcher: {
        enabled: context.activeLocales|length > 1,
        locales: moduleLocales,
    },
}) }}></div>
{% endblock %}

{% block frontend_footer %}
<div {{ vue_component('${MODULE_SLUG}/frontend/${MODULE_NAME}FooterApp', {
    footerText: themeContext.footerText(context.siteName),
}) }}></div>
{% endblock %}
TWIGEOF
    echo -e "  ${GREEN}+${RESET} ${LAYOUT_TWIG}"
fi

# ── Home Vue ────────────────────────────────────────────────────────────────
HOME_VUE="${VUE_DIR}/${MODULE_NAME}HomeApp.vue"
if [[ ! -f "$HOME_VUE" ]]; then
cat > "$HOME_VUE" << 'VUEOF'
<template>
    <div class="space-y-6">
        <p class="text-muted">{{ siteName }}</p>
    </div>
</template>
VUEOF
    echo -e "  ${GREEN}+${RESET} ${HOME_VUE}"
fi

# ── Home Twig ───────────────────────────────────────────────────────────────
if [[ ! -f "$HOME_TWIG" ]]; then
cat > "$HOME_TWIG" << TWIGEOF
{% extends '@${MODULE_NAME}/frontend/layout.html.twig' %}

{% block title %}${MODULE_NAME} - {{ parent() }}{% endblock %}

{% block body %}
<div {{ vue_component('${MODULE_SLUG}/frontend/${MODULE_NAME}HomeApp') }}></div>
{% endblock %}
TWIGEOF
    echo -e "  ${GREEN}+${RESET} ${HOME_TWIG}"
fi

echo ""
echo -e "${GREEN}${BOLD}Done!${RESET} Frontend module ${CYAN}${MODULE_NAME}${RESET} scaffolded."
echo ""
echo -e "${YELLOW}Next steps:${RESET}"
echo -e "  1. Create a ${CYAN}${MODULE_NAME}Front.php${RESET} implementing FrontInterface"
echo -e "  2. Create a ${CYAN}Frontend/HomeController.php${RESET} with route ${CYAN}/${MODULE_SLUG}_front_home${RESET}"
echo -e "  3. Register the Twig namespace ${CYAN}@${MODULE_NAME}${RESET} in config/packages/twig.yaml"
echo -e "  4. Tag ${CYAN}${MODULE_NAME}Front${RESET} with aurora.front in config/services.yaml"
echo ""
