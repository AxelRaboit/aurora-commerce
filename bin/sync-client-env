#!/usr/bin/env bash
#
# Detect every `###> aurora/<name> ###` block declared in aurora-core's .env
# (the canonical template) and ensure it exists in the client project's .env.
#
# Behaviour
# ---------
#   - Missing block → appended verbatim (with default values) to the client .env.
#   - Block already present → left **untouched**, including any value the client
#     has customised.
#   - Symfony / third-party blocks (`###> doctrine/* ###`, `###> symfony/* ###`,
#     etc.) are ignored — those are handled by Flex.
#   - Non-aurora vars the client added themselves are never touched.
#
# Usage (from a client project root)
# ----------------------------------
#   bash vendor/axelraboit/aurora/bin/sync-client-env
#
# Idempotent — safe to call from `make aurora-update` on every run.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
VENDOR_ENV="${SCRIPT_DIR}/../.env"
CLIENT_ENV="${PWD}/.env"

if [[ ! -f "${VENDOR_ENV}" ]]; then
    echo "❌ Vendor .env not found at ${VENDOR_ENV}" >&2
    exit 1
fi

if [[ ! -f "${CLIENT_ENV}" ]]; then
    echo "❌ Client .env not found at ${CLIENT_ENV} — run from the project root." >&2
    exit 1
fi

# Extract block names declared in vendor .env: ###> aurora/foo ### → "aurora/foo"
mapfile -t vendor_blocks < <(
    grep -oE '^###> aurora/[a-zA-Z0-9_-]+ ###' "${VENDOR_ENV}" \
        | sed -E 's/^###> (aurora\/[a-zA-Z0-9_-]+) ###$/\1/' \
        | sort -u
)

if [[ ${#vendor_blocks[@]} -eq 0 ]]; then
    echo "ℹ️  No aurora/* blocks found in vendor .env — nothing to sync."
    exit 0
fi

extract_block() {
    local name="$1"
    awk -v open_marker="###> ${name} ###" -v close_marker="###< ${name} ###" '
        $0 == open_marker  { capture = 1 }
        capture            { print }
        $0 == close_marker { capture = 0 }
    ' "${VENDOR_ENV}"
}

added=0
for block in "${vendor_blocks[@]}"; do
    marker="###> ${block} ###"
    if grep -qxF "${marker}" "${CLIENT_ENV}"; then
        continue
    fi

    # Append a blank line before the new block if the .env doesn't already
    # end with one — keeps the file readable.
    if [[ -n "$(tail -c1 "${CLIENT_ENV}")" ]]; then
        printf '\n' >> "${CLIENT_ENV}"
    elif [[ -z "$(tail -c2 "${CLIENT_ENV}" | head -c1)" ]]; then
        :
    else
        printf '\n' >> "${CLIENT_ENV}"
    fi

    {
        printf '\n'
        extract_block "${block}"
    } >> "${CLIENT_ENV}"
    echo "✅ Added missing block ${block}"
    added=$((added + 1))
done

if [[ ${added} -eq 0 ]]; then
    echo "✅ Client .env already has every aurora/* block — no changes."
fi
