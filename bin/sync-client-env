#!/usr/bin/env bash
#
# Maintain the `###> aurora/<name> ###` blocks aurora-core requires in the
# client project's `.env`, while leaving everything the client owns alone.
#
# Layout enforced
# ---------------
#   ┌──────────────────────────────────────────────────────────┐
#   │  Symfony Flex blocks + aurora/* blocks (managed)         │
#   │  ...                                                     │
#   ├──── # ============ CLIENT CUSTOM ============ ───────────┤
#   │  Client-owned vars (never touched by aurora-update)      │
#   └──────────────────────────────────────────────────────────┘
#
# Behaviour
# ---------
#   - The divider line is added at the end of `.env` if absent (first run).
#   - A missing `###> aurora/* ###` block is inserted just ABOVE the
#     divider — never inside the CLIENT CUSTOM region.
#   - Existing blocks (with any customised values) are never modified.
#   - Lines under the divider are 100% client-owned and untouched.
#
# Usage from a client project root
# --------------------------------
#   bash vendor/axelraboit/aurora/bin/sync-client-env
#
# Idempotent — safe to call repeatedly from `make aurora-update`.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
VENDOR_ENV="${SCRIPT_DIR}/../.env"
CLIENT_ENV="${PWD}/.env"

DIVIDER='# ====================== CLIENT CUSTOM ======================'
DIVIDER_HELP=(
    '# Variables d'\''environnement propres au projet client.'
    '# `make aurora-update` / `make sync-env` ne touchent JAMAIS aux lignes'
    '# en dessous de ce séparateur. Mets ici tes secrets, feature flags,'
    '# intégrations tierces, etc.'
    '# ============================================================'
)

if [[ ! -f "${VENDOR_ENV}" ]]; then
    echo "❌ Vendor .env not found at ${VENDOR_ENV}" >&2
    exit 1
fi

if [[ ! -f "${CLIENT_ENV}" ]]; then
    echo "❌ Client .env not found at ${CLIENT_ENV} — run from the project root." >&2
    exit 1
fi

# ── Step 1: ensure the CLIENT CUSTOM divider exists ──────────────────
if ! grep -qxF "${DIVIDER}" "${CLIENT_ENV}"; then
    if [[ -s "${CLIENT_ENV}" ]] && [[ -n "$(tail -c1 "${CLIENT_ENV}")" ]]; then
        printf '\n' >> "${CLIENT_ENV}"
    fi
    {
        printf '\n%s\n' "${DIVIDER}"
        for line in "${DIVIDER_HELP[@]}"; do
            printf '%s\n' "${line}"
        done
    } >> "${CLIENT_ENV}"
    echo "✅ Added CLIENT CUSTOM divider to .env (anything below it is client-owned)"
fi

# ── Step 2: enumerate aurora/* blocks declared in vendor .env ────────
mapfile -t vendor_blocks < <(
    grep -oE '^###> aurora/[a-zA-Z0-9_-]+ ###' "${VENDOR_ENV}" \
        | sed -E 's/^###> (aurora\/[a-zA-Z0-9_-]+) ###$/\1/' \
        | sort -u
)

if [[ ${#vendor_blocks[@]} -eq 0 ]]; then
    echo "ℹ️  No aurora/* blocks in vendor .env — nothing to sync."
    exit 0
fi

extract_block() {
    local name="$1"
    awk -v open_marker="###> ${name} ###" -v close_marker="###< ${name} ###" '
        $0 == open_marker  { capture = 1 }
        capture            { print }
        $0 == close_marker { capture = 0 }
    ' "${VENDOR_ENV}"
}

insert_before_divider() {
    local name="$1"
    local block_file
    block_file="$(mktemp)"
    extract_block "${name}" > "${block_file}"

    awk -v divider="${DIVIDER}" -v block_file="${block_file}" '
        BEGIN { inserted = 0 }
        $0 == divider && !inserted {
            while ((getline line < block_file) > 0) print line
            close(block_file)
            print ""
            inserted = 1
        }
        { print }
    ' "${CLIENT_ENV}" > "${CLIENT_ENV}.tmp"
    mv "${CLIENT_ENV}.tmp" "${CLIENT_ENV}"
    rm -f "${block_file}"
}

# ── Step 3: insert any missing block just above the divider ───────────
added=0
for block in "${vendor_blocks[@]}"; do
    marker="###> ${block} ###"
    if grep -qxF "${marker}" "${CLIENT_ENV}"; then
        continue
    fi

    insert_before_divider "${block}"
    echo "✅ Added missing block ${block} (above CLIENT CUSTOM divider)"
    added=$((added + 1))
done

if [[ ${added} -eq 0 ]]; then
    echo "✅ Client .env already has every aurora/* block — no changes."
fi
