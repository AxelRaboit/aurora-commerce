#!/usr/bin/env node
/**
 * Generates / updates jsconfig.json in an aurora client project.
 *
 * Run from the client project root:
 *   node vendor/axelraboit/aurora/bin/sync-client-jsconfig
 *
 * Discovers aurora module aliases dynamically by scanning
 * vendor/aurora/src/Module/<X>/assets/. Client modules are scanned the same
 * way under <client>/src/Module/<X>/assets/.
 */

const { readdirSync, writeFileSync, existsSync } = require("fs");
const { resolve, join } = require("path");

const AURORA_DIR   = resolve(__dirname, "..");
const CLIENT_DIR   = process.cwd();
const AURORA_VENDOR = "vendor/axelraboit/aurora";

// Without baseUrl, path values must be relative (TS 5.0+ requirement).
// Aurora 0.5+ : all frontend assets live under src/Core/Frontend/ and
// src/Module/<X>/assets/ (no more root assets/).
const paths = {
    "@/*":       [`./${AURORA_VENDOR}/src/Core/Frontend/*`],
    "@core/*":   [`./${AURORA_VENDOR}/src/Core/Frontend/*`],
    "@shared/*": [`./${AURORA_VENDOR}/src/Core/Frontend/shared/*`],
    "@client/*": ["./assets/client/*"],
};

// Dynamic aurora module aliases — one per src/Module/<Name>/assets/ in aurora
const auroraModulesDir = join(AURORA_DIR, "src", "Module");
if (existsSync(auroraModulesDir)) {
    for (const entry of readdirSync(auroraModulesDir, { withFileTypes: true })) {
        if (!entry.isDirectory()) continue;
        // Only modules that ship a Vue/JS assets/ folder are alias-worthy.
        if (!existsSync(join(auroraModulesDir, entry.name, "assets"))) continue;
        paths[`@${entry.name.toLowerCase()}/*`] = [
            `./${AURORA_VENDOR}/src/Module/${entry.name}/assets/*`,
        ];
    }
}

// Dynamic client module aliases — one per <client>/src/Module/<Name>/assets/.
// Client aliases override aurora aliases with the same name.
const clientSrcModulesDir = join(CLIENT_DIR, "src", "Module");
if (existsSync(clientSrcModulesDir)) {
    for (const entry of readdirSync(clientSrcModulesDir, { withFileTypes: true })) {
        if (!entry.isDirectory()) continue;
        if (!existsSync(join(clientSrcModulesDir, entry.name, "assets"))) continue;
        paths[`@${entry.name.toLowerCase()}/*`] = [
            `./src/Module/${entry.name}/assets/*`,
        ];
    }
}

const jsconfig = {
    compilerOptions: { paths },
    include: [
        "assets/**/*",
        "src/**/*",
        `${AURORA_VENDOR}/src/**/*`,
    ],
};

const dest = join(CLIENT_DIR, "jsconfig.json");
writeFileSync(dest, JSON.stringify(jsconfig, null, 4) + "\n", "utf8");
console.log(`  ✓ jsconfig.json updated (${Object.keys(paths).length} aliases)`);
