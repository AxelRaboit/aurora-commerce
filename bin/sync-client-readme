#!/usr/bin/env bash
#
# Maintain the aurora-canonical block of the client project's README.md
# while leaving the title, intro and project-specific sections untouched.
#
# Layout enforced
# ---------------
#   ┌──────────────────────────────────────────────────────────┐
#   │  # <Project name>            (client-owned)              │
#   │  <intro paragraph>           (client-owned)              │
#   ├── <!-- aurora-canonical:start --> ───────────────────────┤
#   │  Quickstart link, daily commands, CI, doc index          │
#   │  (managed by sync-readme, replaced on each call)         │
#   ├── <!-- aurora-canonical:end --> ─────────────────────────┤
#   │  ## Spécifique à ce projet  (client-owned)               │
#   │  ...                                                     │
#   └──────────────────────────────────────────────────────────┘
#
# Behaviour
# ---------
#   - If README.md is absent → cp the full template as-is.
#   - If README.md exists with both markers → replace the content BETWEEN
#     them with the template's between-markers content. Title/intro/below
#     are preserved.
#   - If README.md exists WITHOUT markers (legacy) → warn the client and
#     leave the file alone. The client adds the markers manually once.
#
# Usage from a client project root
# --------------------------------
#   bash vendor/axelraboit/aurora/bin/sync-client-readme
#
# Idempotent — safe to call from `make aurora-update` / `make pull-update`.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
TEMPLATE="${SCRIPT_DIR}/../.claude/client_template/README.md"
CLIENT_README="${PWD}/README.md"

START_MARKER='<!-- aurora-canonical:start'
END_MARKER='<!-- aurora-canonical:end'
# Anchored patterns — markers MUST be at column 0 (their own line, no prose
# indent). Prevents false positives when the markers are mentioned inside
# the canonical block's prose (e.g. in the "Customisation projet" section
# that references them as text).
START_MARKER_ANCHORED='^<!-- aurora-canonical:start'
END_MARKER_ANCHORED='^<!-- aurora-canonical:end'

if [[ ! -f "${TEMPLATE}" ]]; then
    echo "❌ Template not found at ${TEMPLATE}" >&2
    exit 1
fi

# ── Case 1: README.md absent → fresh seed ──────────────────────────────
if [[ ! -f "${CLIENT_README}" ]]; then
    cp "${TEMPLATE}" "${CLIENT_README}"
    echo "✅ README.md seeded from aurora template (edit title + 'Spécifique à ce projet')"
    exit 0
fi

# ── Case 2: README.md exists → check for markers (anchored at line start) ──
if ! grep -qE "${START_MARKER_ANCHORED}" "${CLIENT_README}"; then
    echo "⚠️  README.md has no '${START_MARKER} …' marker — left as-is."
    echo "    To opt into auto-syncing the aurora-canonical block, wrap the"
    echo "    canonical content (quickstart link, daily commands, CI block,"
    echo "    doc index, customisation note) between these markers:"
    echo ""
    echo "      <!-- aurora-canonical:start — managed by \`make sync-readme\`. Don't edit between markers. -->"
    echo "      ... canonical content ..."
    echo "      <!-- aurora-canonical:end -->"
    echo ""
    echo "    Then re-run \`make sync-readme\`."
    exit 0
fi

if ! grep -qE "${END_MARKER_ANCHORED}" "${CLIENT_README}"; then
    echo "❌ README.md has a start marker but no end marker — refusing to sync." >&2
    echo "   Add '${END_MARKER} -->' on its own line and re-run." >&2
    exit 1
fi

# ── Case 3: replace between-markers content ────────────────────────────
tmp="$(mktemp)"

# Extract template's between-markers content (the marker lines themselves
# are also included on each side so we get a clean replacement). Markers
# are matched by anchored regex — must be at column 0 on their own line.
template_block="$(mktemp)"
awk -v start="${START_MARKER_ANCHORED}" -v end="${END_MARKER_ANCHORED}" '
    $0 ~ start { capture = 1 }
    capture    { print }
    $0 ~ end   { capture = 0 }
' "${TEMPLATE}" > "${template_block}"

if [[ ! -s "${template_block}" ]]; then
    echo "❌ Couldn't extract aurora-canonical block from template (markers missing in template?)" >&2
    rm -f "${template_block}" "${tmp}"
    exit 1
fi

# Replace between-markers content in the client README. Anchored markers
# only — avoids false positives on prose that references them.
awk -v start="${START_MARKER_ANCHORED}" -v end="${END_MARKER_ANCHORED}" -v block_file="${template_block}" '
    $0 ~ start {
        # Print the new block (which already includes the start + end marker lines)
        while ((getline line < block_file) > 0) print line
        close(block_file)
        skip = 1
        next
    }
    skip && $0 ~ end {
        skip = 0
        next
    }
    !skip { print }
' "${CLIENT_README}" > "${tmp}"

# Diff check — only write back if there's actually a change
if cmp -s "${tmp}" "${CLIENT_README}"; then
    echo "✅ README.md aurora-canonical block already in sync — no changes."
    rm -f "${tmp}" "${template_block}"
    exit 0
fi

mv "${tmp}" "${CLIENT_README}"
rm -f "${template_block}"
echo "✅ README.md aurora-canonical block updated (title/intro/'Spécifique à ce projet' preserved)"
