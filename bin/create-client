## Updating Aurora

\`\`\`bash
make aurora-update
\`\`\`

Runs \`composer update axelraboit/aurora\`. Review aurora's changelog before
pulling new versions; entity / interface signatures are stable but
breaking changes will bump the major version.
EOF

# ---------------------------------------------------------------------------
# Git init
# ---------------------------------------------------------------------------

info "Initialising git repository..."
git -C "$DEST" init -q
git -C "$DEST" add .

# ---------------------------------------------------------------------------
# make install
# ---------------------------------------------------------------------------

info "Running make install..."
make -C "$DEST" install

# ---------------------------------------------------------------------------
# Done
# ---------------------------------------------------------------------------

echo ""
success "Project created at ${BOLD}${DEST}${RESET}"
echo ""
echo -e "  ${GREEN}✓${RESET} Admin user: ${CYAN}admin@aurora.app${RESET} / ${CYAN}password${RESET}"
echo -e "  Run ${CYAN}make start${RESET} in ${CYAN}${DEST}${RESET} to launch."
echo ""
