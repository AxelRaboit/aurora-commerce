#!/usr/bin/env bash
set -euo pipefail

# ---------------------------------------------------------------------------
# Aurora — create-client
# Scaffolds a new client project that installs Aurora as a Composer package.
#
# Usage:
#   bin/create-client <project-name> [destination-dir]
#
# Examples:
#   bin/create-client my-client
#   bin/create-client my-client ~/projects/my-client
# ---------------------------------------------------------------------------

RED='\033[0;31m'
GREEN='\033[0;32m'
CYAN='\033[0;36m'
BOLD='\033[1m'
RESET='\033[0m'

info()    { echo -e "${CYAN}→${RESET} $*"; }
success() { echo -e "${GREEN}✓${RESET} $*"; }
error()   { echo -e "${RED}✗ $*${RESET}" >&2; exit 1; }

# ---------------------------------------------------------------------------
# Args
# ---------------------------------------------------------------------------

if [[ $# -lt 1 ]]; then
    echo -e "${BOLD}Usage:${RESET} bin/create-client <project-name> [destination-dir]"
    exit 1
fi

PROJECT_NAME="$1"
DEST="${2:-$(dirname "$(pwd)")/${PROJECT_NAME}}"
AURORA_DIR="$(cd "$(dirname "$0")/.." && pwd)"
AURORA_REMOTE="$(git -C "$AURORA_DIR" remote get-url origin 2>/dev/null || echo 'git@github.com:AxelRaboit/aurora.git')"
AURORA_PACKAGE="$(php -r "echo json_decode(file_get_contents('${AURORA_DIR}/composer.json'))->name;")"
AURORA_BRANCH="$(git -C "$AURORA_DIR" branch --show-current 2>/dev/null || echo 'main')"
AURORA_VERSION="dev-${AURORA_BRANCH}"
VENDOR_NAME="$(echo "$AURORA_REMOTE" | sed 's|.*[:/]\([^/]*\)/[^/]*$|\1|' | tr '[:upper:]' '[:lower:]')"
AURORA_ENV_LOCAL="${AURORA_DIR}/.env.local"
AURORA_VENDOR_PATH="vendor/${AURORA_PACKAGE}"

if [[ -d "$DEST" ]]; then
    error "Directory already exists: $DEST"
fi

echo ""
echo -e "${BOLD}Creating Aurora client project${RESET}"
echo -e "  Name    : ${CYAN}${PROJECT_NAME}${RESET}"
echo -e "  Path    : ${CYAN}${DEST}${RESET}"
echo -e "  Package : ${CYAN}${AURORA_PACKAGE}${RESET} (${AURORA_REMOTE})"
echo ""

# ---------------------------------------------------------------------------
# Directory structure
# ---------------------------------------------------------------------------

info "Creating directory structure..."
mkdir -p "$DEST"/{bin,public,src/{Controller,Entity,Dto,Manager,Serializer,Service,EventListener},templates/Core,config/packages,config/routes,migrations,assets/client/{Module,Overrides}}
touch "$DEST/src/Controller/.gitkeep"
touch "$DEST/src/Entity/.gitkeep"
touch "$DEST/src/Dto/.gitkeep"
touch "$DEST/src/Manager/.gitkeep"
touch "$DEST/src/Serializer/.gitkeep"
touch "$DEST/src/Service/.gitkeep"
touch "$DEST/src/EventListener/.gitkeep"
touch "$DEST/templates/Core/.gitkeep"
touch "$DEST/migrations/.gitkeep"
touch "$DEST/assets/client/Module/.gitkeep"
touch "$DEST/assets/client/Overrides/.gitkeep"

# ---------------------------------------------------------------------------
# composer.json
# ---------------------------------------------------------------------------

info "Writing composer.json..."
cat > "$DEST/composer.json" <<EOF
{
    "name": "${VENDOR_NAME}/${PROJECT_NAME}",
    "description": "Aurora-based client application",
    "type": "project",
    "license": "proprietary",
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require": {
        "php": ">=8.4",
        "symfony/runtime": "7.4.*",
        "${AURORA_PACKAGE}": "${AURORA_VERSION}"
    },
    "require-dev": {
        "doctrine/doctrine-fixtures-bundle": "^4.3.1",
        "phpunit/phpunit": "^13.1.7",
        "symfony/browser-kit": "7.4.*",
        "symfony/css-selector": "7.4.*",
        "symfony/maker-bundle": "^1.67",
        "symfony/web-profiler-bundle": "7.4.*"
    },
    "autoload": {
        "psr-4": {
            "App\\\\": "src/"
        }
    },
    "repositories": [
        {
            "type": "vcs",
            "url": "${AURORA_REMOTE}"
        }
    ],
    "config": {
        "allow-plugins": {
            "php-http/discovery": true,
            "symfony/flex": true,
            "symfony/runtime": true
        }
    }
}
EOF

# ---------------------------------------------------------------------------
# src/Kernel.php
# ---------------------------------------------------------------------------

info "Writing src/Kernel.php..."
mkdir -p "$DEST/src"
cat > "$DEST/src/Kernel.php" <<'EOF'
<?php

declare(strict_types=1);

namespace App;

use Symfony\Bundle\FrameworkBundle\Kernel\MicroKernelTrait;
use Symfony\Component\HttpKernel\Kernel as BaseKernel;

class Kernel extends BaseKernel
{
    use MicroKernelTrait;
}
EOF

# ---------------------------------------------------------------------------
# bin/console
# ---------------------------------------------------------------------------

info "Writing bin/console..."
cat > "$DEST/bin/console" <<'EOF'
#!/usr/bin/env php
<?php

use App\Kernel;
use Symfony\Bundle\FrameworkBundle\Console\Application;

if (!is_dir(dirname(__DIR__).'/vendor')) {
    throw new LogicException('Dependencies are missing. Try running "composer install".');
}

if (!is_file(dirname(__DIR__).'/vendor/autoload_runtime.php')) {
    throw new LogicException('Symfony Runtime is missing. Try running "composer install".');
}

require_once dirname(__DIR__).'/vendor/autoload_runtime.php';

return function (array $context) {
    $kernel = new Kernel($context['APP_ENV'], (bool) $context['APP_DEBUG']);

    return new Application($kernel);
};
EOF
chmod +x "$DEST/bin/console"

# ---------------------------------------------------------------------------
# public/index.php
# ---------------------------------------------------------------------------

info "Writing public/index.php..."
cat > "$DEST/public/index.php" <<'EOF'
<?php

require_once dirname(__DIR__).'/vendor/autoload_runtime.php';

return static function (array $context) {
    return new \App\Kernel($context['APP_ENV'], (bool) $context['APP_DEBUG']);
};
EOF

# ---------------------------------------------------------------------------
# .env
# ---------------------------------------------------------------------------

info "Writing .env..."
cat > "$DEST/.env" <<EOF
###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=change-me-in-env-local
APP_SHARE_DIR=var/share
###< symfony/framework-bundle ###

###> symfony/routing ###
DEFAULT_URI=http://localhost
###< symfony/routing ###

###> doctrine/doctrine-bundle ###
DATABASE_URL="postgresql://app:!ChangeMe!@127.0.0.1:5432/${PROJECT_NAME}?serverVersion=18&charset=utf8"
###< doctrine/doctrine-bundle ###

###> symfony/messenger ###
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0
###< symfony/messenger ###

###> symfony/mailer ###
MAILER_DSN=null://null
MAILER_FROM=noreply@${PROJECT_NAME}.local
ADMIN_EMAIL=admin@${PROJECT_NAME}.local
###< symfony/mailer ###

APP_NAME=${PROJECT_NAME}
EOF

# ---------------------------------------------------------------------------
# .env.local.example + .env.local (pre-filled from aurora's .env.local)
# ---------------------------------------------------------------------------

cat > "$DEST/.env.local.example" <<EOF
APP_SECRET=your-random-secret-here
DATABASE_URL="postgresql://app:password@127.0.0.1:5432/${PROJECT_NAME}?serverVersion=18&charset=utf8"
EOF

if [[ -f "$AURORA_ENV_LOCAL" ]]; then
    info "Pre-filling .env.local from aurora's .env.local..."
    AURORA_DB_URL="$(grep '^DATABASE_URL=' "$AURORA_ENV_LOCAL" | cut -d= -f2- | tr -d '"')"
    AURORA_SECRET="$(grep '^APP_SECRET=' "$AURORA_ENV_LOCAL" | cut -d= -f2-)"
    CLIENT_DB_URL="$(echo "$AURORA_DB_URL" | sed "s|/[^/?]*?|/${PROJECT_NAME//-/_}_dev?|")"
    cat > "$DEST/.env.local" <<EOF
APP_SECRET=${AURORA_SECRET}
DATABASE_URL="${CLIENT_DB_URL}"
EOF
    success ".env.local created"
else
    info "No aurora .env.local found — copy .env.local.example manually"
fi

# ---------------------------------------------------------------------------
# .gitignore
# ---------------------------------------------------------------------------

info "Writing .gitignore..."
cat > "$DEST/.gitignore" <<'EOF'
/.env.local
/.env.*.local
/var/
/vendor/
/node_modules/
/public/build/
/public/bundles/
/public/uploads/
/composer.lock
/.vite/
EOF

# ---------------------------------------------------------------------------
# config/bundles.php
# ---------------------------------------------------------------------------

info "Writing config/bundles.php..."
cp "$AURORA_DIR/config/bundles.php" "$DEST/config/bundles.php"

# ---------------------------------------------------------------------------
# config/packages/*.yaml — copy from aurora, override bundle-managed ones
# ---------------------------------------------------------------------------

info "Copying config/packages from aurora..."
for f in framework mailer messenger routing monolog rate_limiter property_info validator pentatrion_vite web_profiler; do
    [[ -f "$AURORA_DIR/config/packages/${f}.yaml" ]] && \
        cp "$AURORA_DIR/config/packages/${f}.yaml" "$DEST/config/packages/${f}.yaml"
done

# security.yaml — full copy (references Aurora\ classes which are available via the bundle)
cp "$AURORA_DIR/config/packages/security.yaml" "$DEST/config/packages/security.yaml"

# doctrine.yaml — DBAL + ORM mapping for App\Entity
# Aurora's own ORM mappings (App\Module\..., src/Module) are registered by
# AuroraBundle::prependExtension. This file only declares the client-specific
# App\Entity namespace and a placeholder for resolve_target_entities.
cat > "$DEST/config/packages/doctrine.yaml" <<EOF
doctrine:
    dbal:
        url: '%env(resolve:DATABASE_URL)%'
        profiling_collect_backtrace: '%kernel.debug%'
    orm:
        # Map Aurora Core entity interfaces to your concrete subclasses.
        # Uncomment and adapt as you start extending entities under src/Entity/.
        # Example:
        # resolve_target_entities:
        #     Aurora\Core\Agency\Entity\AgencyInterface: App\Entity\Agency
        mappings:
            AppEntity:
                type: attribute
                is_bundle: false
                dir: '%kernel.project_dir%/src/Entity'
                prefix: 'App\Entity'
                alias: AppEntity

when@test:
    doctrine:
        dbal:
            dbname_suffix: '_test%env(default::TEST_TOKEN)%'

when@prod:
    doctrine:
        orm:
            query_cache_driver:
                type: pool
                pool: doctrine.system_cache_pool
            result_cache_driver:
                type: pool
                pool: doctrine.result_cache_pool

    framework:
        cache:
            pools:
                doctrine.result_cache_pool:
                    adapter: cache.app
                doctrine.system_cache_pool:
                    adapter: cache.system
EOF

# doctrine_migrations.yaml — aurora migrations come from bundle, add client namespace here
cat > "$DEST/config/packages/doctrine_migrations.yaml" <<EOF
doctrine_migrations:
    migrations_paths:
        'ClientMigrations': '%kernel.project_dir%/migrations'
EOF

# translation.yaml — locale/fallback only (translation paths registered by AuroraBundle)
cat > "$DEST/config/packages/translation.yaml" <<'EOF'
framework:
    translator:
        fallbacks:
            - fr
EOF

# twig.yaml — strict_variables for test env only (paths registered by AuroraBundle)
cat > "$DEST/config/packages/twig.yaml" <<'EOF'
when@test:
    twig:
        strict_variables: true
EOF

# ---------------------------------------------------------------------------
# config/routes/
# ---------------------------------------------------------------------------

cp "$AURORA_DIR/config/routes/security.yaml" "$DEST/config/routes/security.yaml" 2>/dev/null || true
cp "$AURORA_DIR/config/routes/web_profiler.yaml" "$DEST/config/routes/web_profiler.yaml" 2>/dev/null || true
cp "$AURORA_DIR/config/routes/pentatrion_vite.yaml" "$DEST/config/routes/pentatrion_vite.yaml" 2>/dev/null || true

cat > "$DEST/config/routes/framework.yaml" <<'EOF'
when@dev:
    _errors:
        resource: '@FrameworkBundle/Resources/config/routing/errors.php'
        prefix: /_error
EOF

# ---------------------------------------------------------------------------
# config/routes.yaml
# ---------------------------------------------------------------------------

info "Writing config/routes.yaml..."
cat > "$DEST/config/routes.yaml" <<EOF
# Aurora core controllers
aurora:
    resource: '../${AURORA_VENDOR_PATH}/src/'
    type: attribute

# Client controllers
client:
    resource: '../src/Controller/'
    type: attribute
EOF

# ---------------------------------------------------------------------------
# config/services.yaml
# ---------------------------------------------------------------------------

info "Writing config/services.yaml..."
cat > "$DEST/config/services.yaml" <<EOF
parameters:
    app.admin_email: '%env(ADMIN_EMAIL)%'
    app.mailer_from: '%env(MAILER_FROM)%'

services:
    _defaults:
        autowire: true
        autoconfigure: true

    # Responsibility-based PSR-4 prefixes (Sylius / Symfony convention).
    # Modules with their own bundle-like structure live under App\Module\<Name>.
    # Aurora extension layers (Entity / Dto / Manager / Serializer) sit flat
    # under src/. Use #[AsAlias(<Interface>)] to replace an Aurora default
    # service, or #[AsDecorator] to wrap it.
    App\Controller\:
        resource: '../src/Controller/'
        tags: ['controller.service_arguments']

    App\Entity\:
        resource: '../src/Entity/'

    App\Dto\:
        resource: '../src/Dto/'

    App\Manager\:
        resource: '../src/Manager/'

    App\Serializer\:
        resource: '../src/Serializer/'

    App\Service\:
        resource: '../src/Service/'

    App\EventListener\:
        resource: '../src/EventListener/'

    # Aurora's translation dumper writes JSON files to vendor/aurora/assets/locales/
    # so vue-i18n (running from aurora's app.js) can import them. Add each client
    # module's translations dir to \$extraSourceDirs as you create them, e.g.:
    #     - '%kernel.project_dir%/src/Module/MyModule/translations'
    Aurora\Core\Setting\Command\DumpJsTranslationsCommand:
        arguments:
            \$auroraDir: '%kernel.project_dir%/${AURORA_VENDOR_PATH}'
            \$extraSourceDirs: []
EOF

# ---------------------------------------------------------------------------
# .env.test
# ---------------------------------------------------------------------------

cat > "$DEST/.env.test" <<'EOF'
KERNEL_CLASS='App\Kernel'
APP_ENV=test
APP_DEBUG=1
EOF

# ---------------------------------------------------------------------------
# Makefile
# ---------------------------------------------------------------------------

info "Writing Makefile..."
cp "$AURORA_DIR/Makefile" "$DEST/Makefile"

# Point AURORA to the composer vendor path
sed -i "s|^AURORA        = \.$|AURORA        = ${AURORA_VENDOR_PATH}|" "$DEST/Makefile"

# Remove targets overridden by client-specific versions (avoids make warnings)
for target in install-dev install-prod deploy-prod aurora-update start build dev fixtures; do
    awk -v t="$target" '/^[a-zA-Z]/{ in_target=($0 ~ "^"t":") } !in_target{ print }' \
        "$DEST/Makefile" > "$DEST/Makefile.tmp" && mv "$DEST/Makefile.tmp" "$DEST/Makefile"
done

# Append client-specific overrides
cat "$AURORA_DIR/bin/client-makefile-overrides.mk" >> "$DEST/Makefile"

# ---------------------------------------------------------------------------
# jsconfig.json — IDE path aliases (Volar/VS Code)
# Without this, the editor cannot resolve the @ alias (defined in vendor/aurora
# vite.config.js, invisible from the client root) so autocomplete and
# go-to-definition would not work in assets/client/ files.
# ---------------------------------------------------------------------------

info "Writing jsconfig.json (auto-generated from aurora module list)..."
node "${AURORA_DIR}/bin/sync-client-jsconfig"

# ---------------------------------------------------------------------------
# rector.php — standalone config scoped to src/ so Rector doesn't warn about
# scanning a path inside vendor/ (aurora's own tools/rector/rector.php uses
# __DIR__/../../src which resolves into vendor/ when called from a client).
# ---------------------------------------------------------------------------

info "Writing rector.php..."
cat > "$DEST/rector.php" <<'EOF'
<?php

declare(strict_types=1);

use Rector\Caching\ValueObject\Storage\FileCacheStorage;
use Rector\Config\RectorConfig;

return RectorConfig::configure()
    ->withPaths([__DIR__.'/src'])
    ->withSkip([__DIR__.'/config'])
    ->withImportNames(removeUnusedImports: true)
    ->withPhpSets(php84: true)
    ->withPreparedSets(
        codeQuality: true,
        codingStyle: true,
        privatization: true,
        instanceOf: true,
        earlyReturn: true
    )
    ->withTypeCoverageLevel(36)
    ->withDeadCodeLevel(40)
    ->withComposerBased(
        doctrine: true,
        symfony: true
    )
    ->withCache(__DIR__.'/var/cache/rector', FileCacheStorage::class);
EOF

# ---------------------------------------------------------------------------
# package.json (shared runtime deps for client Vue components)
# ---------------------------------------------------------------------------

info "Writing package.json..."
AURORA_PKG="$AURORA_DIR/package.json"
read_dep() {
    php -r "echo json_decode(file_get_contents('${AURORA_PKG}'))->dependencies->{'$1'} ?? '';"
}
cat > "$DEST/package.json" <<EOF
{
    "private": true,
    "license": "UNLICENSED",
    "description": "Shared runtime deps for client Vue components. Aurora's vite.config.js dedupes these so we still get a single instance at runtime.",
    "dependencies": {
        "axios": "$(read_dep axios)",
        "lucide-vue-next": "$(read_dep lucide-vue-next)",
        "vue": "$(read_dep vue)",
        "vue-i18n": "$(read_dep vue-i18n)",
        "vue-sonner": "$(read_dep vue-sonner)"
    }
}
EOF

# ---------------------------------------------------------------------------
# README.md
# ---------------------------------------------------------------------------

info "Writing README.md..."
cat > "$DEST/README.md" <<EOF
# ${PROJECT_NAME}

A client application built on [Aurora](${AURORA_REMOTE}).
Aurora is installed as a Composer dependency at \`${AURORA_VENDOR_PATH}/\`.

---

## Setup

\`\`\`bash
cp .env.local.example .env.local   # fill in your DB credentials
make install                       # composer + pnpm + DB + migrate + fixtures
make demo                          # load demo fixtures
make start                         # PHP server + Vite dev server
\`\`\`

\`make\` lists all targets. The most useful: \`start\`, \`demo\`, \`cc\`, \`aurora-update\`.

---

## Where do I put my code? — Cheatsheet

The project follows the **Sylius / Symfony convention**: flat,
responsibility-based folders under \`src/\`. There is no \`Custom/\` umbrella —
overrides live next to the layer they extend.

### PHP (under \`src/\`)

| I want to… | Drop file at… | How it's wired |
|---|---|---|
| Add a page (controller + route) | \`src/Controller/MyController.php\` | \`#[Route]\` attribute, scanned automatically |
| Add a domain service | \`src/Service/MyService.php\` | autowired |
| Override an Aurora service | \`src/Manager/MyAgencyManager.php\` (or \`Serializer/\`, \`Service/\`, …) | \`#[AsAlias(AuroraInterface::class)]\` |
| Decorate an Aurora service | same folder as above | \`#[AsDecorator(AuroraService::class)]\` |
| Listen to an Aurora event | \`src/EventListener/MyListener.php\` | \`#[AsEventListener(AuroraEvent::class)]\` |
| Extend an Aurora entity | \`src/Entity/MyAgency.php\` extending \`AbstractAurora<Name>\` | \`resolve_target_entities\` in \`config/packages/doctrine.yaml\` |
| Extend an Aurora DTO | \`src/Dto/MyInput.php\` extending \`Aurora\\…\\<Name>Input\` | \`#[AsAlias]\` on the matching Factory |
| Build a feature module | \`src/Module/<Name>/\` mirroring Aurora's module layout | \`tags: [aurora.module]\` in \`services.yaml\` |

### Templates (\`templates/\`)

| I want to… | Drop file at… |
|---|---|
| Override an Aurora template | \`templates/Core/<mirrored-Aurora-path>.html.twig\` *(auto-resolved before vendor's)* |
| Add a template for a feature module | \`templates/Module/<Name>/...html.twig\` |

### Vue (\`assets/client/\`)

| I want to… | Drop file at… | \`vue_component()\` lookup |
|---|---|---|
| Wrap an Aurora Vue component | \`assets/client/Overrides/<mirrored-Aurora-path>.vue\` | \`<mirrored-path-without-.vue>\` (no module prefix) |
| Vue components for a feature module | \`assets/client/Module/<Name>/<rest>.vue\` | \`<name>/<rest>\` |

### Migrations (\`migrations/\`)

\`\`\`bash
php bin/console doctrine:migrations:diff --namespace=ClientMigrations
# review the generated file (delete parasite SQL: seq_log, messenger_messages)
make migrate
\`\`\`

---

## Project layout

\`\`\`
${PROJECT_NAME}/
├── vendor/axelraboit/aurora/   # Aurora core (read-only)
├── src/
│   ├── Controller/             # App\Controller\*
│   ├── Entity/                 # App\Entity\*       — entity overrides (extends AbstractAurora<Name>)
│   ├── Dto/                    # App\Dto\*          — DTO overrides
│   ├── Manager/                # App\Manager\*      — manager overrides / decorators
│   ├── Serializer/             # App\Serializer\*   — serializer overrides / decorators
│   ├── Service/                # App\Service\*      — domain services
│   ├── EventListener/          # App\EventListener\*
│   └── Module/<Name>/          # App\Module\<Name>\* — feature module
├── templates/
│   ├── Core/                   # Override Aurora's @Core templates (auto-resolved before vendor's)
│   └── Module/<Name>/          # Module-specific templates
├── assets/client/
│   ├── Module/<Name>/          # Vue components for feature modules
│   └── Overrides/              # Vue wrappers around Aurora components
├── migrations/                 # Doctrine migrations (ClientMigrations namespace)
├── config/
│   ├── packages/               # doctrine.yaml, twig.yaml, security.yaml…
│   ├── routes.yaml
│   └── services.yaml
├── bin/console
└── public/index.php
\`\`\`

